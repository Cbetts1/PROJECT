#!/bin/sh

OS_ROOT="${OS_ROOT:-/}"
export PATH="$OS_ROOT/bin:$OS_ROOT/sbin:$PATH"

STATE="$OS_ROOT/var/service"
PIDFILE="$STATE/os-kernel.pid"
PROCFILE="$OS_ROOT/proc/os"
STATEFILE="$OS_ROOT/proc/os.state"
LOG="$OS_ROOT/var/log/os.log"
HEALTH="$STATE/os-kernel.health"

mkdir -p "$STATE" "$OS_ROOT/proc" "$OS_ROOT/var/log"

write_health() {
    echo "status=$1
time=$(date +%s)
pid=${2:-}" > "$HEALTH"
}

start() {
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        if [ -d "/proc/$pid" ]; then
            echo "[os-kernel] Already running (pid=$pid)"
            return 0
        fi
        rm -f "$PIDFILE"
    fi

    # Write kernel personality
    [ -f "$PROCFILE" ] && [ -d "$PROCFILE" ] && rm -rf "$PROCFILE"
    cat > "$PROCFILE" << EOP
OS_NAME="AIOS-Lite"
OS_VERSION="0.1"
OS_VENDOR="Chris"
EOP

    # Start kernel daemon in background, capture its PID
    (
        echo $$ > "$PIDFILE"
        echo "boot_time=$(date +%s)
kernel_pid=$$
os_version=0.1
runlevel=3
last_heartbeat=$(date +%s)" > "$STATEFILE"
        write_health "running" "$$"
        os-event "kernel: started pid=$$" 2>/dev/null
        os-msg   "kernel: started pid=$$" 2>/dev/null
        while true; do
            echo "[os-kernel] heartbeat $$" >> "$LOG"
            os-event "kernel: heartbeat pid=$$" 2>/dev/null
            # Update heartbeat timestamp only (keep boot_time)
            boot_t=$(awk -F= '/boot_time/ {print $2}' "$STATEFILE" 2>/dev/null)
            echo "boot_time=${boot_t:-$(date +%s)}
kernel_pid=$$
os_version=0.1
runlevel=3
last_heartbeat=$(date +%s)" > "$STATEFILE"
            write_health "running" "$$"
            sleep 5
        done
    ) &
    echo "[os-kernel] Started (pid=$!)"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null
        rm -f "$PIDFILE"
        write_health "stopped"
        os-event "kernel: stopped pid=$pid" 2>/dev/null
        os-msg   "kernel: stopped pid=$pid" 2>/dev/null
        echo "[os-kernel] Stopped."
    else
        echo "[os-kernel] Not running."
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)
        if [ -f "$PIDFILE" ] && [ -d "/proc/$(cat "$PIDFILE")" ]; then
            echo "os-kernel: running (pid=$(cat "$PIDFILE"))"
        else
            echo "os-kernel: stopped"
        fi
        ;;
    *) echo "Usage: os-kernel {start|stop|restart|status}" ;;
esac
