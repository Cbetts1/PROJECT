#!/bin/sh

OS_ROOT="${OS_ROOT:-/}"
HEALTH="$OS_ROOT/var/service/banner.health"

health() { mkdir -p "$(dirname "$HEALTH")"; echo "$1" > "$HEALTH"; }

case "$1" in
  start)
    echo "================================"
    echo "       AIOS-Lite v0.1"
    echo "  AI-Augmented Operating System"
    echo "================================"
    if [ -f "$OS_ROOT/etc/os-release" ]; then
      . "$OS_ROOT/etc/os-release"
    fi
    echo "Name:    ${PRETTY_NAME:-AIOS-Lite}"
    echo "Version: ${VERSION_ID:-0.1}"
    echo "Kernel:  $(uname -r 2>/dev/null || echo unknown)"
    echo "Arch:    $(uname -m 2>/dev/null || echo unknown)"
    echo "================================"
    health "status=ok"
    ;;
  stop)
    health "status=stopped"
    ;;
  status)
    if [ -f "$HEALTH" ]; then
      cat "$HEALTH"
    else
      echo "status=unknown"
    fi
    ;;
  *)
    echo "Usage: banner {start|stop|status}"
    ;;
esac
