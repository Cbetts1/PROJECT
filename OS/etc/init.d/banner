OS_ROOT="${OS_ROOT:-/}"
HEALTH="$OS_ROOT/var/service/banner.health"
health() { echo "$1" > "$HEALTH"; }

#!/bin/sh

case "$1" in
  start)
    echo "=== OS Boot ==="
    if [ -n "$OS_ROOT" ] && [ -f "$OS_ROOT/etc/os-release" ]; then
      . "$OS_ROOT/etc/os-release"
    elif [ -f /etc/os-release ]; then
      . /etc/os-release
    fi
    echo "Name: $PRETTY_NAME"
    echo "Version: $VERSION_ID"
    echo "Kernel: $(uname -r)"
    ;;
esac
