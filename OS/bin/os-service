#!/bin/sh
# os-service — Manage PROJECT OS services
# Subcommands: start, stop, status, enable, disable, list

OS_ROOT="${OS_ROOT:-/}"
RC2="$OS_ROOT/etc/rc2.d"
INITD="$OS_ROOT/etc/init.d"
PIDDIR="$OS_ROOT/var/service"
PROC_SVC="$OS_ROOT/proc/os/services"
AURA_LOG="$OS_ROOT/var/log/aura.log"

_log() {
    ts=$(date '+%Y-%m-%dT%H:%M:%SZ')
    echo "[$ts] [os-service] $*" >> "$AURA_LOG" 2>/dev/null
}

_update_proc() {
    # Update a service status entry in proc/os/services
    svc="$1"; new_status="$2"
    if [ -f "$PROC_SVC" ]; then
        # Replace existing line or append
        if grep -q "^${svc}=" "$PROC_SVC" 2>/dev/null; then
            tmp=$(mktemp)
            sed "s|^${svc}=.*|${svc}=${new_status}|" "$PROC_SVC" > "$tmp" && mv "$tmp" "$PROC_SVC"
        else
            echo "${svc}=${new_status}" >> "$PROC_SVC"
        fi
    fi
}

cmd="${1:-help}"
svc="$2"

case "$cmd" in
  start)
    if [ -z "$svc" ]; then echo "Usage: os-service start <service>" >&2; exit 1; fi
    script="$INITD/$svc"
    if [ ! -f "$script" ] && [ ! -x "$script" ]; then
        echo "[os-service] No init script for '$svc' at $script" >&2; exit 1
    fi
    echo "[os-service] Starting $svc ..."
    if sh "$script" start; then
        _update_proc "$svc" "running"
        _log "started: $svc"
        echo "[os-service] $svc started."
    else
        _update_proc "$svc" "failed"
        _log "start failed: $svc"
        echo "[os-service] $svc failed to start." >&2; exit 1
    fi
    ;;

  stop)
    if [ -z "$svc" ]; then echo "Usage: os-service stop <service>" >&2; exit 1; fi
    script="$INITD/$svc"
    pidfile="$PIDDIR/$svc.pid"
    # Try init script stop first
    if [ -f "$script" ]; then
        sh "$script" stop 2>/dev/null
    fi
    # Kill by PID file if present
    if [ -f "$pidfile" ]; then
        pid=$(cat "$pidfile")
        kill "$pid" 2>/dev/null && echo "[os-service] Sent SIGTERM to $svc (pid $pid)."
        sleep 1
        kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
        rm -f "$pidfile"
    fi
    _update_proc "$svc" "stopped"
    _log "stopped: $svc"
    echo "[os-service] $svc stopped."
    ;;

  status)
    if [ -z "$svc" ]; then
        # Show all service statuses
        echo "Service Status"
        echo "=============="
        if [ -f "$PROC_SVC" ]; then
            grep -v '^#' "$PROC_SVC" | while IFS='=' read -r name stat; do
                [ -z "$name" ] && continue
                pidfile="$PIDDIR/$name.pid"
                if [ -f "$pidfile" ]; then
                    pid=$(cat "$pidfile")
                    [ -d "/proc/$pid" ] && live="running(pid=$pid)" || live="dead(stale)"
                    printf "  %-20s %s\n" "$name" "$live"
                else
                    printf "  %-20s %s\n" "$name" "${stat:-stopped}"
                fi
            done
        else
            echo "  (service registry not found at $PROC_SVC)"
        fi
    else
        pidfile="$PIDDIR/$svc.pid"
        if [ -f "$pidfile" ]; then
            pid=$(cat "$pidfile")
            if [ -d "/proc/$pid" ]; then
                echo "$svc: running (pid $pid)"
            else
                echo "$svc: dead (stale pid file)"
            fi
        else
            # Fall back to proc/os/services entry
            entry=$(grep "^${svc}=" "$PROC_SVC" 2>/dev/null | head -1 | cut -d= -f2-)
            echo "$svc: ${entry:-stopped}"
        fi
    fi
    ;;

  enable)
    if [ -z "$svc" ]; then echo "Usage: os-service enable <service>" >&2; exit 1; fi
    mkdir -p "$RC2"
    ln -sf "../init.d/$svc" "$RC2/S99-$svc"
    _log "enabled: $svc"
    echo "Enabled: $svc"
    ;;

  disable)
    if [ -z "$svc" ]; then echo "Usage: os-service disable <service>" >&2; exit 1; fi
    rm -f "$RC2/"*"$svc"
    _log "disabled: $svc"
    echo "Disabled: $svc"
    ;;

  list)
    echo "Enabled services (rc2.d):"
    if [ -d "$RC2" ]; then
        ls "$RC2" 2>/dev/null | sed 's/^/  /'
    else
        echo "  (rc2.d not found)"
    fi
    ;;

  *)
    echo "Usage: os-service {start|stop|status|enable|disable|list} [<service>]"
    ;;
esac
