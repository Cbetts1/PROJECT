#!/bin/sh
# os-msg — Send a message to the AIOS-Lite message log and bus

OS_ROOT="${OS_ROOT:-/}"
MSGFILE="$OS_ROOT/proc/os.messages"
LOGFILE="$OS_ROOT/var/log/messages.log"
BUS_LOG="$OS_ROOT/var/log/bus.log"

mkdir -p "$OS_ROOT/proc"
touch "$MSGFILE"
mkdir -p "$OS_ROOT/var/log"
touch "$LOGFILE"

timestamp=$(date '+%Y-%m-%d %H:%M:%S')
msg="$*"

echo "[$timestamp] $msg" >> "$MSGFILE"
echo "[$timestamp] $msg" >> "$LOGFILE"

# Publish to the message bus (append-log format matching bus.mod)
echo "[$timestamp] [messages] $msg" >> "$BUS_LOG"
