#!/bin/sh
# © 2026 Chris Betts | AIOSCPU Official | AI-generated, fully legal

OS_ROOT="${OS_ROOT:-/}"
export PATH="$PATH:$OS_ROOT/bin:$OS_ROOT/sbin"

# History and job control
HISTFILE="${OS_ROOT}/var/log/shell.history"
HISTSIZE=1000

IDENTITY="$OS_ROOT/proc/os.identity"
STATEFILE="$OS_ROOT/proc/os.state"
MSGFILE="$OS_ROOT/proc/os.messages"
EVENTLOG="$OS_ROOT/var/log/events.log"
AURA_LOG="$OS_ROOT/var/log/aura.log"
FS_PY="$OS_ROOT/lib/filesystem.py"

HEALTHDIR="$OS_ROOT/var/service"
MODDIR="$OS_ROOT/lib/aura-mods"
AGENTDIR="$OS_ROOT/lib/aura-agents"
POLICYDIR="$OS_ROOT/lib/aura-policy"
TASKDIR="$OS_ROOT/lib/aura-tasks"
MEMDIR="$OS_ROOT/lib/aura-memory"
SEMDIR="$OS_ROOT/lib/aura-semantic"
HYBDIR="$OS_ROOT/lib/aura-hybrid"
LLMDIR="$OS_ROOT/lib/aura-llm"
BRIDGEDIR="$OS_ROOT/lib/aura-bridge"

MEMROOT="$OS_ROOT/proc/aura/memory"
SEMROOT="$OS_ROOT/proc/aura/semantic"
mkdir -p "$MEMROOT" "$SEMROOT" "$OS_ROOT/proc/aura/context" "$OS_ROOT/var/log"

# Load identity
[ -f "$IDENTITY" ] && . "$IDENTITY"

# Source login profile (user customisation point)
[ -f "$OS_ROOT/etc/aura/profile" ] && . "$OS_ROOT/etc/aura/profile" 2>/dev/null

shell_name="${OS_NAME:-Aura}"
host="${OS_NAME:-AIOS}"
version="${OS_VERSION:-0.1}"

# === Personality Engine ===
AURA_MODE="operator"
AURA_MEMORY="$OS_ROOT/proc/aura.memory"
touch "$AURA_MEMORY" 2>/dev/null

aura_say() {
    case "$AURA_MODE" in
        operator) echo "[$shell_name] $*" ;;
        system)   echo "[SYS:$shell_name] $*" ;;
        talk)     echo "$shell_name: $*" ;;
    esac
}

aura_prompt() {
    cwd=$(pwd | sed "s|$OS_ROOT||")
    [ -z "$cwd" ] && cwd="/"
    case "$AURA_MODE" in
        operator) printf '%s:%s$ ' "$host" "$cwd" ;;
        system)   printf '[SYS]%s:%s# ' "$host" "$cwd" ;;
        talk)     printf '(%s)> ' "$shell_name" ;;
    esac
}

# === AURA Audit Log ===
# Logs every command and AI decision to OS/var/log/aura.log
aura_log() {
    ts=$(date '+%Y-%m-%dT%H:%M:%SZ')
    echo "[$ts] [shell] $*" >> "$AURA_LOG"
}

# === Load Engines ===
. "$MEMDIR/engine.mod"
. "$SEMDIR/embed.mod"
. "$SEMDIR/engine.mod"
. "$HYBDIR/engine.mod"
. "$POLICYDIR/engine.mod"
. "$POLICYDIR/actions.mod"
. "$LLMDIR/llm.mod"
. "$BRIDGEDIR/detect.mod"
. "$BRIDGEDIR/ios.mod"
. "$BRIDGEDIR/android.mod"
. "$BRIDGEDIR/linux.mod"
. "$BRIDGEDIR/mirror.mod"
. "$MODDIR/sysinfo.mod"

# === Termux API helpers (only active on android-termux) ===
_IS_TERMUX=0
if [ -n "${TERMUX_VERSION:-}" ] || [ -d "/data/data/com.termux" ]; then
    _IS_TERMUX=1
    # Prefer Termux's own prefix for tools
    TERMUX_PREFIX="${PREFIX:-/data/data/com.termux/files/usr}"
    export PATH="$TERMUX_PREFIX/bin:$PATH"
fi

# === Fuzzy Command Matching (awk Levenshtein) ===
# All known commands — used for typo suggestion / intent correction.
KNOWN_CMDS="ask recall recall.best ctx.show ctx.add sem.set sem.get sem.search sem.delete sem.list mem.set mem.get mem.search mem.delete mem.tag mem.list bridge bridge.detect bridge.ios bridge.android mirror mirror.mount mirror.unmount mirror.ls msg event mode status services ps info help exit quit sysinfo uptime disk ls cd read write start stop restart kill upgrade history jobs bg fg repair termux termux.info termux.notify termux.vibrate termux.clipboard termux.battery termux.shell"

cmd_fuzzy_match() {
    input="$1"
    awk -v input="$input" -v cmds="$KNOWN_CMDS" '
    function min3(a, b, c,    m) {
        m = (a < b) ? a : b
        return (m < c) ? m : c
    }
    function lev(s, t,    m, n, i, j, cost, dtbl) {
        m = length(s)
        n = length(t)
        if (m == 0) return n
        if (n == 0) return m
        for (i = 0; i <= m; i++) dtbl[i,0] = i
        for (j = 0; j <= n; j++) dtbl[0,j] = j
        for (i = 1; i <= m; i++) {
            for (j = 1; j <= n; j++) {
                cost = (substr(s,i,1) == substr(t,j,1)) ? 0 : 1
                dtbl[i,j] = min3(dtbl[i-1,j]+1, dtbl[i,j-1]+1, dtbl[i-1,j-1]+cost)
            }
        }
        return dtbl[m,n]
    }
    BEGIN {
        n = split(cmds, ca, " ")
        best = 999
        bestcmd = ""
        for (i = 1; i <= n; i++) {
            dist = lev(input, ca[i])
            if (dist < best) { best = dist; bestcmd = ca[i] }
        }
        if (best <= 2) print bestcmd
    }' /dev/null
}

# === Filesystem helpers (OS_ROOT isolated via filesystem.py) ===
_fs() { OS_ROOT="$OS_ROOT" python3 "$FS_PY" "$@" 2>/dev/null; }

# Validate that a path stays within OS_ROOT (for shell-native cd)
_path_safe() {
    target_abs=$(cd "$1" 2>/dev/null && pwd)
    [ -z "$target_abs" ] && return 1
    case "$target_abs" in
        "$OS_ROOT"|"$OS_ROOT/"*) return 0 ;;
        *) return 1 ;;
    esac
}

banner() {
    echo "================================"
    echo "   $shell_name Shell  v$version"
    echo "  AI-Augmented Operating System"
    echo "================================"
    host_os=$(detect_host_os)
    echo "Host OS: $host_os"
    if bin=$(llm_available) 2>/dev/null; then
        echo "AI:      $bin ($(basename "$(llm_model 2>/dev/null)" 2>/dev/null || echo 'model not found'))"
    else
        echo "AI:      rule-based fallback"
    fi
    echo "Memories: symbolic + semantic + context"
    echo "Type 'help' for commands."
    echo "================================"
    echo "  Powered by AURA | Built on Termux, llama.cpp, Python"
    echo "  Thanks: OpenAI/ChatGPT · Microsoft/Copilot · Google"
    echo "          Meta AI/LLaMA · Termux Project · Open Source"
    echo "================================"
}

help_cmd() {
    cat << 'EOH'
=== AIOS-Lite Shell Commands ===

AI / LLM:
  ask <text>           Ask the AI a question
  mode <m>             Set personality: operator | system | talk

Hybrid Memory:
  recall <text>        Hybrid recall (context + semantic + symbolic)
  recall.best <text>   Best single answer
  ctx.show             Show context window
  ctx.add <text>       Add to context window

Semantic Memory:
  sem.set <k> <v>      Store semantic memory
  sem.get <k>          Retrieve by key
  sem.search <text>    Search by similarity
  sem.delete <k>       Delete entry
  sem.list             List all entries

Symbolic Memory:
  mem.set <k> <v>      Store key-value memory
  mem.get <k>          Retrieve by key
  mem.search <p>       Search by pattern
  mem.delete <k>       Delete entry
  mem.tag <k> <tags>   Tag a memory entry
  mem.list             List all entries

Cross-OS Bridge & Mirror:
  bridge               Show bridge status
  bridge.detect        Detect connected devices
  bridge.ios           iOS device info
  bridge.android       Android device info
  mirror               Show mirror status
  mirror.mount <t>     Mount: ios | android | linux | auto
  mirror.unmount <t>   Unmount: ios | android | linux | all
  mirror.ls [t] [p]    List mirrored files

System:
  sysinfo              OS name, version, kernel, uptime
  uptime               Time since boot
  disk                 Disk usage under OS root
  msg <text>           Send message to message bus
  event <text>         Fire system event
  status               Show full OS state
  services             Show service status
  ps                   List processes
  info                 System information
  exit                 Exit shell

Termux (Android only — available when running inside Termux):
  termux.info          Show Termux environment details
  termux.notify <msg>  Send a system notification (needs termux-api)
  termux.vibrate       Vibrate the device (needs termux-api)
  termux.clipboard     Get/set clipboard (needs termux-api)
  termux.battery       Show battery status (needs termux-api)
  termux.shell         Drop to a full Termux/bash shell (type 'exit' to return)

AURA Self-Repair:
  repair               Run AURA self-repair (fixes missing dirs, logs, configs)

Files (OS_ROOT isolated):
  ls [path]            List files/directories
  cd <path>            Change directory (confined to OS_ROOT)
  read <file>          Print file contents
  write <file> <text>  Append text to file

Services:
  start <svc>          Start init.d service
  stop <svc>           Stop init.d service
  restart <svc>        Restart init.d service

Packages:
  upgrade              Check installed packages for upgrades
  upgrade --apply      Apply all pending package upgrades

History & Jobs:
  history [n]          Show last n commands (default: 20)
  history -c           Clear history
  jobs                 List background jobs
  fg [n]               Wait for background job n (default: last)
  bg <cmd> [args]      Run command in background
EOH
}

# === History helpers ===
_hist_load() {
    mkdir -p "$(dirname "$HISTFILE")"
    touch "$HISTFILE" 2>/dev/null || true
}

_hist_append() {
    [ -z "$1" ] && return
    echo "$1" >> "$HISTFILE"
    # Trim to HISTSIZE
    total=$(wc -l < "$HISTFILE" 2>/dev/null | tr -d ' ')
    if [ "$total" -gt "$HISTSIZE" ]; then
        tail -n "$HISTSIZE" "$HISTFILE" > "$HISTFILE.tmp" && mv "$HISTFILE.tmp" "$HISTFILE"
    fi
}

_hist_show() {
    n="${1:-20}"
    if [ ! -f "$HISTFILE" ]; then echo "(no history)"; return; fi
    total=$(wc -l < "$HISTFILE" 2>/dev/null | tr -d ' ')
    start=$(( total - n + 1 ))
    [ "$start" -lt 1 ] && start=1
    awk -v s="$start" 'NR>=s {printf "%5d  %s\n", NR, $0}' "$HISTFILE"
}

# === Job control ===
# Jobs stored as lines in "$OS_ROOT/var/service/jobs.table": "N PID CMD"
JOBFILE="$OS_ROOT/var/service/jobs.table"

_job_add() {
    pid="$1"; shift; cmd="$*"
    mkdir -p "$(dirname "$JOBFILE")"
    n=$(( $(wc -l < "$JOBFILE" 2>/dev/null | tr -d ' ') + 1 ))
    echo "$n $pid $cmd" >> "$JOBFILE"
    echo "[${n}] $pid"
}

_job_list() {
    [ -f "$JOBFILE" ] || { echo "No background jobs."; return; }
    while read -r jn jpid jcmd; do
        if [ -d "/proc/$jpid" ]; then
            printf '[%s] Running   %s  %s\n' "$jn" "$jpid" "$jcmd"
        else
            printf '[%s] Done      %s  %s\n' "$jn" "$jpid" "$jcmd"
        fi
    done < "$JOBFILE"
}

_job_fg() {
    n="${1:-}"
    [ -f "$JOBFILE" ] || { echo "No background jobs."; return; }
    if [ -z "$n" ]; then
        # Read last job entry
        jn=$(tail -1 "$JOBFILE" | awk '{print $1}')
        jpid=$(tail -1 "$JOBFILE" | awk '{print $2}')
    else
        jn="$n"
        jpid=$(awk -v n="$n" '$1==n {print $2}' "$JOBFILE")
    fi
    [ -z "$jpid" ] && { echo "No such job: $n"; return 1; }
    echo "[${jn}] Waiting for PID $jpid ..."
    wait "$jpid" 2>/dev/null
    echo "[${jn}] Done."
}

# === Start Shell ===
banner
_hist_load
aura_log "shell started (mode=$AURA_MODE)"

# === AURA startup self-check ===
# Run the Python repair bot once at startup so AURA can patch any missing dirs/files.
_aios_home="${AIOS_HOME:-$(cd "$OS_ROOT/.." 2>/dev/null && pwd)}"
if command -v python3 >/dev/null 2>&1 && [ -f "$_aios_home/ai/core/ai_backend.py" ]; then
    _repair_out=$(OS_ROOT="$OS_ROOT" python3 "$_aios_home/ai/core/ai_backend.py" "repair self" 2>/dev/null)
    [ -n "$_repair_out" ] && aura_log "startup repair: $_repair_out"
fi
unset _aios_home _repair_out

_pending=""   # holds a corrected command to re-dispatch without re-reading stdin

while true; do
    if [ -n "$_pending" ]; then
        line="$_pending"
        _pending=""
    else
        aura_prompt
        IFS= read -r line || exit 0
        # Append to history (skip blank and history commands)
        case "$line" in
            ""|history*) ;;
            *) _hist_append "$line" ;;
        esac
    fi
    [ -z "$line" ] && continue

    # Handle background job: line ending with ' &'
    _bg_mode=0
    case "$line" in
        *" &"|*"	&")
            _bg_mode=1
            line="${line% &}"
            line="${line%	&}"
            ;;
    esac

    ctx_add "$line"
    set -- $line
    cmd="$1"

    # Log every command to aura.log for auditability
    aura_log "CMD: $line"

    # Run in background if & was appended
    if [ "$_bg_mode" -eq 1 ]; then
        ( eval "$line" ) &
        _job_add "$!" "$line"
        continue
    fi

    case "$cmd" in
        ask)
            shift
            [ -z "$*" ] && { aura_say "Usage: ask <question>"; continue; }
            response=$(llm_query "$*")
            ctx_add "ai: $response"
            aura_log "AI: $response"
            echo "$response"
            ;;
        recall)
            shift; hybrid_recall "$*" ;;
        recall.best)
            shift; hybrid_best "$*" ;;
        ctx.show)
            ctx_get ;;
        ctx.add)
            shift; ctx_add "$*"; aura_say "Added to context." ;;
        sem.set)
            shift; key="$1"; shift; semantic_store "$key" "$*"; aura_say "Semantic memory stored." ;;
        sem.get)
            shift; semantic_get "$1" ;;
        sem.search)
            shift; semantic_search "$*" ;;
        sem.delete)
            shift; semantic_delete "$1"; aura_say "Semantic memory deleted." ;;
        sem.list)
            semantic_list ;;
        mem.set)
            shift; key="$1"; shift; mem_set "$key" "$*"; aura_say "Memory stored." ;;
        mem.get)
            shift; mem_get "$1" ;;
        mem.search)
            shift; mem_search "$1" ;;
        mem.delete)
            shift; mem_delete "$1"; aura_say "Memory deleted." ;;
        mem.tag)
            shift; key="$1"; shift; mem_tag "$key" "$*"; aura_say "Tagged." ;;
        mem.list)
            mem_list ;;
        bridge)
            cat "$OS_ROOT/proc/aura/bridge/status" 2>/dev/null || aura_say "Bridge not initialized." ;;
        bridge.detect)
            bridge_summary ;;
        bridge.ios)
            ios_device_info ;;
        bridge.android)
            android_devices ;;
        mirror)
            mirror_status ;;
        mirror.mount)
            shift; mirror_mount "$@" ;;
        mirror.unmount)
            shift; mirror_unmount "${1:-all}" ;;
        mirror.ls)
            shift; mirror_ls "$@" ;;
        msg)
            shift
            os-msg "$*"
            aura_say "Message sent." ;;
        event)
            shift
            os-event "$*"
            aura_say "Event fired." ;;
        mode)
            shift
            case "$1" in
                operator|system|talk) AURA_MODE="$1"; aura_say "Mode: $AURA_MODE" ;;
                *) aura_say "Modes: operator | system | talk" ;;
            esac
            ;;
        status)
            os-state ;;
        services)
            os-service-status ;;
        ps)
            os-ps ;;
        info)
            os-info ;;

        # === SYSTEM commands ===
        sysinfo)
            echo "=== System Info ==="
            # Identity (proc/os.identity is authoritative; proc/os is runtime)
            if [ -f "$IDENTITY" ]; then
                _sname=$(awk -F'"' '/OS_NAME/ {print $2}' "$IDENTITY")
                _sver=$(awk -F'"' '/OS_VERSION/ {print $2}' "$IDENTITY")
                _svend=$(awk -F'"' '/OS_VENDOR/ {print $2}' "$IDENTITY")
                echo "Name:    ${_sname:-unknown}"
                echo "Version: ${_sver:-unknown}"
                echo "Vendor:  ${_svend:-unknown}"
            fi
            if [ -f "$STATEFILE" ]; then
                boot_t=$(awk -F= '/^boot_time=/ {print $2}' "$STATEFILE")
                kpid=$(awk -F= '/^kernel_pid=/ {print $2}' "$STATEFILE")
                now=$(date +%s)
                up=$((now - ${boot_t:-now}))
                echo "Kernel PID: ${kpid:-unknown}"
                echo "Uptime:  ${up}s"
            fi
            echo "Host OS: $(detect_host_os 2>/dev/null)"
            echo "==================="
            ;;
        uptime)
            if [ -f "$STATEFILE" ]; then
                boot_t=$(awk -F= '/^boot_time=/ {print $2}' "$STATEFILE")
                now=$(date +%s)
                up=$((now - ${boot_t:-now}))
                echo "Uptime: ${up}s (since $(date -d "@${boot_t:-0}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -r "${boot_t:-0}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'boot'))"
            else
                echo "Uptime: unknown (no state file)"
            fi
            ;;
        disk)
            echo "=== Disk Usage ==="
            df -h "$OS_ROOT" 2>/dev/null || df -h . 2>/dev/null
            echo "==================="
            ;;

        # === FILE commands (OS_ROOT isolated via filesystem.py) ===
        ls)
            shift
            _target="${1:-.}"
            if command -v python3 >/dev/null 2>&1 && [ -f "$FS_PY" ]; then
                _fs list "$_target" || aura_say "Cannot list: $_target"
            else
                ls -la "$OS_ROOT/$_target" 2>/dev/null || aura_say "Cannot list: $_target"
            fi
            ;;
        cd)
            shift
            if [ -z "$1" ]; then
                cd "$OS_ROOT" 2>/dev/null || true
            else
                _dest="$OS_ROOT/${1#/}"
                if [ -d "$_dest" ] && _path_safe "$_dest"; then
                    cd "$_dest" || aura_say "Cannot cd to: $1"
                else
                    aura_say "No such directory or access denied: $1"
                fi
            fi
            ;;
        read)
            shift
            if [ -z "$1" ]; then
                aura_say "Usage: read <file>"
            elif command -v python3 >/dev/null 2>&1 && [ -f "$FS_PY" ]; then
                _fs read "$1" || aura_say "Cannot read: $1"
            else
                cat "$OS_ROOT/${1#/}" 2>/dev/null || aura_say "Cannot read: $1"
            fi
            ;;
        write)
            shift
            if [ -z "$1" ] || [ -z "$2" ]; then
                aura_say "Usage: write <file> <text>"
            elif command -v python3 >/dev/null 2>&1 && [ -f "$FS_PY" ]; then
                _file="$1"; shift
                _fs append "$_file" "$*
" && aura_say "Written to $_file."
            else
                _file="$OS_ROOT/${1#/}"; shift
                echo "$*" >> "$_file" && aura_say "Written to $_file."
            fi
            ;;

        # === SERVICE commands ===
        start)
            shift
            if [ -z "$1" ]; then
                aura_say "Usage: start <service>"
            elif [ -f "$OS_ROOT/etc/init.d/$1" ]; then
                aura_log "SERVICE start: $1"
                sh "$OS_ROOT/etc/init.d/$1" start
            else
                aura_say "Unknown service: $1 (check $OS_ROOT/etc/init.d/)"
            fi
            ;;
        stop)
            shift
            if [ -z "$1" ]; then
                aura_say "Usage: stop <service>"
            elif [ -f "$OS_ROOT/etc/init.d/$1" ]; then
                aura_log "SERVICE stop: $1"
                sh "$OS_ROOT/etc/init.d/$1" stop
            else
                aura_say "Unknown service: $1 (check $OS_ROOT/etc/init.d/)"
            fi
            ;;
        restart)
            shift
            if [ -z "$1" ]; then
                aura_say "Usage: restart <service>"
            elif [ -f "$OS_ROOT/etc/init.d/$1" ]; then
                aura_log "SERVICE restart: $1"
                sh "$OS_ROOT/etc/init.d/$1" restart
            else
                aura_say "Unknown service: $1 (check $OS_ROOT/etc/init.d/)"
            fi
            ;;
        kill)
            shift
            if [ -z "$1" ]; then
                aura_say "Usage: kill <service>"
            elif [ -f "$OS_ROOT/etc/init.d/$1" ]; then
                aura_log "SERVICE kill: $1"
                sh "$OS_ROOT/etc/init.d/$1" stop
            else
                aura_say "Unknown service: $1"
            fi
            ;;

        help)
            help_cmd ;;
        repair)
            aura_log "CMD: repair"
            aura_say "Running AURA self-repair..."
            _aios_home="${AIOS_HOME:-$(cd "$OS_ROOT/.." 2>/dev/null && pwd)}"
            if command -v python3 >/dev/null 2>&1 && [ -f "$_aios_home/ai/core/ai_backend.py" ]; then
                _rout=$(OS_ROOT="$OS_ROOT" python3 "$_aios_home/ai/core/ai_backend.py" "repair self" 2>/dev/null)
                [ -n "$_rout" ] && echo "$_rout" || aura_say "Self-repair complete."
                aura_log "repair result: ${_rout:-ok}"
            else
                aura_say "AURA Python backend not available; running shell-level repair..."
                mkdir -p "$OS_ROOT/var/log" "$OS_ROOT/var/service" \
                         "$OS_ROOT/proc/aura/context" "$OS_ROOT/proc/aura/memory" \
                         "$OS_ROOT/proc/aura/semantic" "$OS_ROOT/proc/aura/bridge"
                for _lf in os.log aura.log events.log; do
                    [ -f "$OS_ROOT/var/log/$_lf" ] || touch "$OS_ROOT/var/log/$_lf"
                done
                [ -f "$OS_ROOT/proc/os.messages" ] || touch "$OS_ROOT/proc/os.messages"
                aura_say "Shell-level repair complete."
            fi
            ;;
        termux|termux.info)
            if [ "$_IS_TERMUX" -eq 0 ]; then
                aura_say "Termux commands are only available inside Termux on Android."
            else
                echo "=== Termux Environment ==="
                echo "TERMUX_VERSION : ${TERMUX_VERSION:-unknown}"
                echo "PREFIX         : ${TERMUX_PREFIX:-unknown}"
                echo "HOME           : $HOME"
                echo "ANDROID_ROOT   : ${ANDROID_ROOT:-/system}"
                uname -a
                echo "=========================="
            fi
            ;;
        termux.notify)
            shift
            if [ "$_IS_TERMUX" -eq 0 ]; then
                aura_say "Termux commands are only available inside Termux."
            elif [ -z "$*" ]; then
                aura_say "Usage: termux.notify <message>"
            elif command -v termux-notification >/dev/null 2>&1; then
                termux-notification --title "AIOS" --content "$*"
                aura_say "Notification sent."
                aura_log "termux.notify: $*"
            else
                aura_say "termux-notification not available. Install: pkg install termux-api"
            fi
            ;;
        termux.vibrate)
            if [ "$_IS_TERMUX" -eq 0 ]; then
                aura_say "Termux commands are only available inside Termux."
            elif command -v termux-vibrate >/dev/null 2>&1; then
                termux-vibrate -d 300
                aura_say "Vibrated."
            else
                aura_say "termux-vibrate not available. Install: pkg install termux-api"
            fi
            ;;
        termux.clipboard)
            shift
            if [ "$_IS_TERMUX" -eq 0 ]; then
                aura_say "Termux commands are only available inside Termux."
            elif [ -z "$*" ]; then
                if command -v termux-clipboard-get >/dev/null 2>&1; then
                    termux-clipboard-get
                else
                    aura_say "termux-clipboard-get not available. Install: pkg install termux-api"
                fi
            else
                if command -v termux-clipboard-set >/dev/null 2>&1; then
                    echo "$*" | termux-clipboard-set
                    aura_say "Copied to clipboard."
                else
                    aura_say "termux-clipboard-set not available. Install: pkg install termux-api"
                fi
            fi
            ;;
        termux.battery)
            if [ "$_IS_TERMUX" -eq 0 ]; then
                aura_say "Termux commands are only available inside Termux."
            elif command -v termux-battery-status >/dev/null 2>&1; then
                termux-battery-status
            else
                aura_say "termux-battery-status not available. Install: pkg install termux-api"
            fi
            ;;
        termux.shell)
            if [ "$_IS_TERMUX" -eq 0 ]; then
                aura_say "Termux commands are only available inside Termux."
            else
                aura_say "Dropping to Termux shell. Type 'exit' to return to AIOS."
                aura_log "termux.shell: dropping to Termux"
                "${SHELL:-/data/data/com.termux/files/usr/bin/bash}" || true
                aura_say "Returned from Termux shell."
            fi
            ;;
        upgrade)
            aura_log "CMD: upgrade $*"
            shift
            _upgrade_flag="${1:---check}"
            if command -v os-install >/dev/null 2>&1; then
                case "$_upgrade_flag" in
                    --apply|apply)
                        aura_say "Upgrading all installed packages..."
                        os-install upgrade-all
                        ;;
                    *)
                        aura_say "Checking installed packages..."
                        os-install list
                        aura_say "To apply upgrades: upgrade --apply"
                        ;;
                esac
            else
                aura_say "os-install not found."
            fi
            ;;
        exit|quit)
            aura_log "shell exit"
            aura_say "Goodbye."; exit 0 ;;
        history)
            shift
            case "$1" in
                -c) > "$HISTFILE"; aura_say "History cleared." ;;
                *)  _hist_show "${1:-20}" ;;
            esac
            ;;
        jobs)
            _job_list ;;
        fg)
            shift; _job_fg "$1" ;;
        bg)
            shift
            [ -z "$*" ] && { aura_say "Usage: bg <cmd> [args]"; continue; }
            ( eval "$*" ) &
            _job_add "$!" "$*"
            ;;
        "")
            ;;
        *)
            # === Fuzzy command matching (typo correction) ===
            suggestion=$(cmd_fuzzy_match "$cmd")
            if [ -n "$suggestion" ]; then
                aura_log "TYPO: '$cmd' -> '$suggestion'"
                aura_say "Unknown command '$cmd'. Auto-correcting to '$suggestion'..."
                shift
                _pending="$suggestion${*:+ $*}"
            else
                # Route to AI
                response=$(llm_query "$line")
                ctx_add "ai: $response"
                aura_log "AI: $response"
                echo "$response"
            fi
            ;;
    esac
done
