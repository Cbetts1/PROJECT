#!/bin/sh
# os-real-shell — AIOS Full OS Shell
# © 2026 Chris Betts | AIOSCPU Official | AI-generated, fully legal
#
# A real POSIX shell augmented with AIOS commands: direct access to the host
# OS filesystem, network, package management, device mounting, and AURA AI.
# Unlike os-shell (which is confined to OS_ROOT), os-real-shell runs with
# full host OS privileges and integrates AIOS intelligence on top.

OS_ROOT="${OS_ROOT:-$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)}"
export OS_ROOT
export PATH="$PATH:$OS_ROOT/bin:$OS_ROOT/sbin"

AURA_LOG="$OS_ROOT/var/log/aura.log"
REAL_SHELL_LOG="$OS_ROOT/var/log/real-shell.log"
FS_PY="$OS_ROOT/lib/filesystem.py"
IDENTITY="$OS_ROOT/proc/os.identity"
STATEFILE="$OS_ROOT/proc/os.state"

mkdir -p "$OS_ROOT/var/log"

# ---------------------------------------------------------------------------
# AURA helpers
# ---------------------------------------------------------------------------

_rlog() {
    ts=$(date '+%Y-%m-%dT%H:%M:%SZ')
    echo "[$ts] [real-shell] $*" >> "$AURA_LOG"
    echo "[$ts] $*" >> "$REAL_SHELL_LOG"
}

# Load identity for branding
[ -f "$IDENTITY" ] && . "$IDENTITY"
SHELL_NAME="${OS_NAME:-AIOS}"
VERSION="${OS_VERSION:-0.1}"

# ---------------------------------------------------------------------------
# Load AURA modules (best-effort — real-shell can run without them)
# ---------------------------------------------------------------------------
_load_mod() { [ -f "$1" ] && . "$1"; }
_load_mod "$OS_ROOT/lib/aura-memory/engine.mod"
_load_mod "$OS_ROOT/lib/aura-semantic/embed.mod"
_load_mod "$OS_ROOT/lib/aura-semantic/engine.mod"
_load_mod "$OS_ROOT/lib/aura-hybrid/engine.mod"
_load_mod "$OS_ROOT/lib/aura-llm/llm.mod"
_load_mod "$OS_ROOT/lib/aura-bridge/detect.mod"
_load_mod "$OS_ROOT/lib/aura-bridge/ios.mod"
_load_mod "$OS_ROOT/lib/aura-bridge/android.mod"
_load_mod "$OS_ROOT/lib/aura-bridge/linux.mod"
_load_mod "$OS_ROOT/lib/aura-bridge/mirror.mod"

mkdir -p "$OS_ROOT/proc/aura/memory" "$OS_ROOT/proc/aura/semantic" \
          "$OS_ROOT/proc/aura/context" "$OS_ROOT/proc/aura/bridge"
[ -f "$OS_ROOT/proc/aura/context/window" ] || touch "$OS_ROOT/proc/aura/context/window"

# ---------------------------------------------------------------------------
# Prompt
# ---------------------------------------------------------------------------
_real_prompt() {
    user=$(id -un 2>/dev/null || echo "user")
    host=$(hostname -s 2>/dev/null || echo "aios")
    cwd=$(pwd)
    printf '\033[1;32m%s@%s\033[0m:\033[1;34m%s\033[0m\033[1;33m[AIOS]\033[0m$ ' "$user" "$host" "$cwd"
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
_banner() {
    cat << EOF
════════════════════════════════════════════════
   $SHELL_NAME Real Shell  v$VERSION
   Full OS Access + AI Augmentation
════════════════════════════════════════════════
  Host OS : $(uname -s -r 2>/dev/null | tr '\n' ' ')
  User    : $(id 2>/dev/null)
  CWD     : $(pwd)
EOF
    if command -v python3 >/dev/null 2>&1 && [ -f "$FS_PY" ]; then
        echo "  FS-Py   : active (OS_ROOT=$OS_ROOT)"
    fi
    if type llm_available >/dev/null 2>&1 && bin=$(llm_available 2>/dev/null); then
        echo "  AI      : $bin ready"
    else
        echo "  AI      : rule-based fallback"
    fi
    cat << 'EOF'
  Type 'help' for AIOS commands, or any real shell command.
════════════════════════════════════════════════
EOF
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
_help() {
    cat << 'EOF'
════ AIOS Real Shell Commands ════════════════════════

AI / Memory (same as os-shell):
  ai <question>          Ask the AI assistant
  recall <text>          Hybrid memory recall
  mem.set <k> <v>        Store symbolic memory
  mem.get <k>            Read symbolic memory
  sem.set <k> <v>        Store semantic memory
  sem.search <text>      Semantic search

System / Info:
  sysinfo                Full host system info
  netinfo                Network interface info
  diskinfo               Disk usage summary
  proclist               Running processes (AI-filtered)
  logread [file]         Read a system/AIOS log file
  thermal                CPU temperature (if available)

Package Management:
  pkg install <pkg>      Install system package (apt/pkg/brew)
  pkg remove  <pkg>      Remove system package
  pkg update             Update package lists
  pkg upgrade            Upgrade all packages
  pkg list               List installed packages

Device / Network:
  mount.ios              Mount iOS device via ifuse
  mount.android          Mount Android via ADB
  mount.usb              Mount first USB block device
  umount.all             Unmount all AIOS mirror devices
  wifi.scan              Scan for WiFi networks
  wifi.connect <ssid>    Connect to WiFi (via nmcli)
  bt.scan                Scan for Bluetooth devices
  net.up <iface>         Bring up network interface
  net.down <iface>       Bring down network interface

Scripting / Tasks:
  run <script>           Execute a shell script with logging
  patch <file>           Apply a patch file (guided by AI)
  update.aios            Pull latest AIOS repo updates
  service.start <svc>    Start a systemd/init.d service
  service.stop  <svc>    Stop a service
  service.status <svc>   Check service status

AIOS:
  os-shell               Switch to AIOS sandbox shell (OS_ROOT confined)
  aura.status            Show full AURA state
  aura.log               Tail AURA audit log
  mode <m>               Set AI mode: operator|system|talk
  help                   Show this help
  exit / quit            Exit real shell
EOF
}

# ---------------------------------------------------------------------------
# Detect package manager
# ---------------------------------------------------------------------------
_pkg_mgr() {
    if command -v apt-get >/dev/null 2>&1; then echo "apt"
    elif command -v apt >/dev/null 2>&1; then echo "apt"
    elif command -v pkg >/dev/null 2>&1; then echo "pkg"
    elif command -v brew >/dev/null 2>&1; then echo "brew"
    elif command -v dnf >/dev/null 2>&1; then echo "dnf"
    elif command -v yum >/dev/null 2>&1; then echo "yum"
    elif command -v pacman >/dev/null 2>&1; then echo "pacman"
    elif command -v apk >/dev/null 2>&1; then echo "apk"
    else echo "unknown"; fi
}

_pkg_cmd() {
    mgr=$(_pkg_mgr)
    case "$mgr" in
        apt)    echo "apt-get" ;;
        pkg)    echo "pkg" ;;
        brew)   echo "brew" ;;
        dnf)    echo "dnf" ;;
        yum)    echo "yum" ;;
        pacman) echo "pacman" ;;
        apk)    echo "apk" ;;
        *)      echo ""; return 1 ;;
    esac
}

# ---------------------------------------------------------------------------
# Network helpers
# ---------------------------------------------------------------------------
_netinfo() {
    echo "=== Network Interfaces ==="
    if command -v ip >/dev/null 2>&1; then
        ip -brief addr show 2>/dev/null
    elif command -v ifconfig >/dev/null 2>&1; then
        ifconfig 2>/dev/null | grep -E "^[a-z]|inet "
    else
        echo "(no ip/ifconfig found)"
    fi
    echo ""
    echo "=== Default Route ==="
    if command -v ip >/dev/null 2>&1; then
        ip route show default 2>/dev/null || echo "none"
    elif command -v route >/dev/null 2>&1; then
        route -n 2>/dev/null | head -5
    fi
    echo "==========================="
}

# ---------------------------------------------------------------------------
# Thermal
# ---------------------------------------------------------------------------
_thermal() {
    found=0
    if [ -d /sys/class/thermal ]; then
        for zone in /sys/class/thermal/thermal_zone*/temp; do
            [ -f "$zone" ] || continue
            temp=$(cat "$zone" 2>/dev/null)
            zname=$(dirname "$zone" | xargs basename)
            printf '%-20s %s°C\n' "$zname" "$((temp / 1000))"
            found=1
        done
    fi
    if [ "$found" -eq 0 ]; then
        if command -v vcgencmd >/dev/null 2>&1; then
            vcgencmd measure_temp 2>/dev/null
        elif command -v sensors >/dev/null 2>&1; then
            sensors 2>/dev/null | grep -i "temp\|°C\|°F"
        else
            echo "Thermal sensors not available on this platform."
        fi
    fi
}

# ---------------------------------------------------------------------------
# USB mount
# ---------------------------------------------------------------------------
_mount_usb() {
    echo "[usb] Scanning for USB block devices..."
    blk=$(lsblk -lno NAME,TYPE,MOUNTPOINT 2>/dev/null | awk '$2=="part" && $3=="" {print $1; exit}')
    if [ -z "$blk" ]; then
        echo "[usb] No unmounted USB partition found."
        return 1
    fi
    mp="$OS_ROOT/mirror/usb"
    mkdir -p "$mp"
    echo "[usb] Mounting /dev/$blk at $mp ..."
    if mount "/dev/$blk" "$mp" 2>/dev/null; then
        echo "[usb] Mounted at $mp"
        _rlog "USB mount: /dev/$blk -> $mp"
    else
        echo "[usb] Mount failed (may need root). Try: sudo mount /dev/$blk $mp"
    fi
}

# ---------------------------------------------------------------------------
# WiFi
# ---------------------------------------------------------------------------
_wifi_scan() {
    if command -v nmcli >/dev/null 2>&1; then
        nmcli dev wifi list 2>/dev/null
    elif command -v iwlist >/dev/null 2>&1; then
        iface=$(ip link show | awk -F: '$2~/wl/{print $2;exit}' | xargs)
        iwlist "${iface:-wlan0}" scan 2>/dev/null | grep -E "ESSID|Signal|Quality"
    elif command -v termux-wifi-scaninfo >/dev/null 2>&1; then
        termux-wifi-scaninfo 2>/dev/null
    else
        echo "[wifi] No wifi scanning tool found (nmcli/iwlist/termux-wifi-scaninfo)."
    fi
}

_wifi_connect() {
    ssid="$1"
    if [ -z "$ssid" ]; then echo "Usage: wifi.connect <ssid>"; return 1; fi
    if command -v nmcli >/dev/null 2>&1; then
        nmcli dev wifi connect "$ssid"
    elif command -v termux-wifi-enable >/dev/null 2>&1; then
        echo "[wifi] Use Android WiFi settings for $ssid (Termux cannot connect directly)."
    else
        echo "[wifi] nmcli not available. Connect manually or via your system network manager."
    fi
}

# ---------------------------------------------------------------------------
# Bluetooth
# ---------------------------------------------------------------------------
_bt_scan() {
    if command -v bluetoothctl >/dev/null 2>&1; then
        echo "[bt] Scanning 5 seconds..."
        bluetoothctl scan on &
        BT_PID=$!
        sleep 5
        kill "$BT_PID" 2>/dev/null
        bluetoothctl devices 2>/dev/null
    elif command -v termux-bluetooth-scaninfo >/dev/null 2>&1; then
        termux-bluetooth-scaninfo 2>/dev/null
    else
        echo "[bt] No bluetooth tool found (bluetoothctl/termux-bluetooth-scaninfo)."
    fi
}

# ---------------------------------------------------------------------------
# Patch helper (AI-guided)
# ---------------------------------------------------------------------------
_patch_file() {
    file="$1"
    [ -z "$file" ] && { echo "Usage: patch <patchfile>"; return 1; }
    [ -f "$file" ] || { echo "File not found: $file"; return 1; }

    echo "[patch] Applying patch: $file"
    _rlog "patch apply: $file"

    if command -v patch >/dev/null 2>&1; then
        patch -p1 < "$file" && echo "[patch] Applied successfully." || echo "[patch] Patch failed."
    else
        echo "[patch] 'patch' command not found. Install with: $(_pkg_cmd) install patch"
    fi
}

# ---------------------------------------------------------------------------
# AIOS update (git pull)
# ---------------------------------------------------------------------------
_update_aios() {
    REPO="${AIOS_HOME:-$(cd "$OS_ROOT/.." 2>/dev/null && pwd)}"
    echo "[update] Pulling latest AIOS from $REPO ..."
    if [ -d "$REPO/.git" ]; then
        (cd "$REPO" && git pull --ff-only 2>&1)
        _rlog "update.aios: git pull in $REPO"
    else
        echo "[update] Not a git repository: $REPO"
        echo "[update] Download from: https://github.com/Cbetts1/PROJECT"
    fi
}

# ---------------------------------------------------------------------------
# Service helpers (systemd / init.d / os-shell services)
# ---------------------------------------------------------------------------
_service_cmd() {
    action="$1"; svc="$2"
    [ -z "$svc" ] && { echo "Usage: service.$action <name>"; return 1; }

    # Try OS init.d first
    if [ -f "$OS_ROOT/etc/init.d/$svc" ]; then
        sh "$OS_ROOT/etc/init.d/$svc" "$action"
        _rlog "service $action: $svc (init.d)"
        return
    fi

    # Try systemd
    if command -v systemctl >/dev/null 2>&1; then
        systemctl "$action" "$svc" 2>&1
        _rlog "service $action: $svc (systemd)"
        return
    fi

    # Try SysV init
    if command -v service >/dev/null 2>&1; then
        service "$svc" "$action" 2>&1
        _rlog "service $action: $svc (sysv)"
        return
    fi

    echo "[service] Unknown service: $svc (no init.d, systemd, or service command)"
}

# ---------------------------------------------------------------------------
# Fuzzy match (same algorithm as os-shell)
# ---------------------------------------------------------------------------
KNOWN_CMDS_REAL="ai recall mem.set mem.get sem.set sem.search sysinfo netinfo diskinfo proclist logread thermal pkg mount.ios mount.android mount.usb umount.all wifi.scan wifi.connect bt.scan net.up net.down run patch update.aios service.start service.stop service.status os-shell aura.status aura.log mode help exit quit"

_fuzzy_real() {
    input="$1"
    awk -v input="$input" -v cmds="$KNOWN_CMDS_REAL" '
    function min3(a, b, c,   m) { m=(a<b)?a:b; return (m<c)?m:c }
    function lev(s, t,   m, n, i, j, cost, d) {
        m=length(s); n=length(t)
        if(m==0) return n; if(n==0) return m
        for(i=0;i<=m;i++) d[i,0]=i
        for(j=0;j<=n;j++) d[0,j]=j
        for(i=1;i<=m;i++) for(j=1;j<=n;j++) {
            cost=(substr(s,i,1)==substr(t,j,1))?0:1
            d[i,j]=min3(d[i-1,j]+1,d[i,j-1]+1,d[i-1,j-1]+cost)
        }
        return d[m,n]
    }
    BEGIN {
        n=split(cmds,ca," "); best=999; bc=""
        for(i=1;i<=n;i++){dist=lev(input,ca[i]); if(dist<best){best=dist;bc=ca[i]}}
        if(best<=2) print bc
    }' /dev/null
}

# ---------------------------------------------------------------------------
# AI mode (shared with os-shell)
# ---------------------------------------------------------------------------
AURA_MODE="operator"

_aura_say() {
    case "$AURA_MODE" in
        operator) echo "[${SHELL_NAME}] $*" ;;
        system)   echo "[SYS:${SHELL_NAME}] $*" ;;
        talk)     echo "${SHELL_NAME}: $*" ;;
    esac
}

# ---------------------------------------------------------------------------
# Main REPL
# ---------------------------------------------------------------------------
_banner
_rlog "real-shell started"

_pending=""

while true; do
    if [ -n "$_pending" ]; then
        line="$_pending"; _pending=""
    else
        _real_prompt
        IFS= read -r line || { echo; _aura_say "Goodbye."; _rlog "EOF exit"; exit 0; }
    fi
    [ -z "$line" ] && continue

    _rlog "CMD: $line"
    # Add to context window for AI continuity
    type ctx_add >/dev/null 2>&1 && ctx_add "$line"

    set -- $line
    cmd="$1"

    case "$cmd" in
        # ---- AI / Memory ----
        ai)
            shift; [ -z "$*" ] && { _aura_say "Usage: ai <question>"; continue; }
            if type llm_query >/dev/null 2>&1; then
                resp=$(llm_query "$*")
                type ctx_add >/dev/null 2>&1 && ctx_add "ai: $resp"
            else
                resp="AI module not loaded."
            fi
            echo "$resp"
            ;;
        recall)   shift; type hybrid_recall >/dev/null 2>&1 && hybrid_recall "$*" || echo "(memory module not loaded)" ;;
        recall.best) shift; type hybrid_best >/dev/null 2>&1 && hybrid_best "$*" || echo "(memory module not loaded)" ;;
        mem.set)  shift; k="$1"; shift; type mem_set >/dev/null 2>&1 && { mem_set "$k" "$*"; _aura_say "Stored."; } || echo "(memory module not loaded)" ;;
        mem.get)  shift; type mem_get >/dev/null 2>&1 && mem_get "$1" || echo "(memory module not loaded)" ;;
        mem.list) type mem_list >/dev/null 2>&1 && mem_list || echo "(memory module not loaded)" ;;
        sem.set)  shift; k="$1"; shift; type semantic_store >/dev/null 2>&1 && { semantic_store "$k" "$*"; _aura_say "Stored."; } ;;
        sem.search) shift; type semantic_search >/dev/null 2>&1 && semantic_search "$*" ;;

        # ---- System Info ----
        sysinfo)
            echo "=== Host System ==="
            uname -a 2>/dev/null
            [ -f /etc/os-release ] && grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"'
            echo "CPU cores: $(nproc 2>/dev/null || grep -c processor /proc/cpuinfo 2>/dev/null || echo '?')"
            free -h 2>/dev/null | head -3
            echo "==================="
            ;;
        netinfo)  _netinfo ;;
        diskinfo)
            echo "=== Disk Usage ==="
            df -h 2>/dev/null | grep -v tmpfs | head -15
            echo "==================="
            ;;
        proclist)
            echo "=== Top Processes ==="
            if command -v ps >/dev/null 2>&1; then
                ps aux --sort=-%cpu 2>/dev/null | head -15 || ps -e 2>/dev/null | head -15
            fi
            echo "====================="
            ;;
        logread)
            shift
            target="${1:-$AURA_LOG}"
            # Allow short names: aura, os, real, events, bridge, kernel
            case "$target" in
                aura)    target="$AURA_LOG" ;;
                os)      target="$OS_ROOT/var/log/os.log" ;;
                real)    target="$REAL_SHELL_LOG" ;;
                events)  target="$OS_ROOT/var/log/events.log" ;;
                bridge)  target="$OS_ROOT/var/log/bridge.log" ;;
                kernel)  target="/var/log/kern.log" ;;
                syslog)  target="/var/log/syslog" ;;
            esac
            echo "=== $target (last 40 lines) ==="
            tail -n 40 "$target" 2>/dev/null || echo "(not found: $target)"
            echo "==========================="
            ;;
        thermal)  _thermal ;;

        # ---- Package Management ----
        pkg)
            shift; subcmd="$1"; shift
            mgr=$(_pkg_mgr)
            if [ "$mgr" = "unknown" ]; then
                echo "[pkg] No supported package manager found."
                continue
            fi
            case "$subcmd" in
                install) _rlog "pkg install: $*"; $(_pkg_cmd) install "$@" ;;
                remove)  _rlog "pkg remove: $*"; $(_pkg_cmd) remove "$@" ;;
                update)  _rlog "pkg update"; $(_pkg_cmd) update ;;
                upgrade) _rlog "pkg upgrade"; $(_pkg_cmd) upgrade ;;
                list)    $(_pkg_cmd) list --installed 2>/dev/null || $(_pkg_cmd) list 2>/dev/null | head -40 ;;
                *)       echo "Usage: pkg {install|remove|update|upgrade|list} [pkg]" ;;
            esac
            ;;

        # ---- Device Mounting ----
        mount.ios)
            type ios_mount >/dev/null 2>&1 && ios_mount || echo "[ios] Bridge module not loaded." ;;
        mount.android)
            type android_mount >/dev/null 2>&1 && android_mount || echo "[android] Bridge module not loaded." ;;
        mount.usb)    _mount_usb ;;
        umount.all)
            type mirror_unmount >/dev/null 2>&1 && mirror_unmount all || echo "[mirror] Mirror module not loaded." ;;

        # ---- Network ----
        wifi.scan)       _wifi_scan ;;
        wifi.connect)    shift; _wifi_connect "$@" ;;
        bt.scan)         _bt_scan ;;
        net.up)
            shift; [ -z "$1" ] && { echo "Usage: net.up <iface>"; continue; }
            ip link set "$1" up 2>/dev/null || ifconfig "$1" up 2>/dev/null
            _rlog "net.up: $1"
            ;;
        net.down)
            shift; [ -z "$1" ] && { echo "Usage: net.down <iface>"; continue; }
            ip link set "$1" down 2>/dev/null || ifconfig "$1" down 2>/dev/null
            _rlog "net.down: $1"
            ;;

        # ---- Scripting / Tasks ----
        run)
            shift
            [ -z "$*" ] && { echo "Usage: run <script>"; continue; }
            _rlog "run: $*"
            sh "$@"
            ;;
        patch)  shift; _patch_file "$1" ;;
        update.aios) _update_aios ;;

        # ---- Services ----
        service.start)  shift; _service_cmd start "$1" ;;
        service.stop)   shift; _service_cmd stop "$1" ;;
        service.restart) shift; _service_cmd restart "$1" ;;
        service.status) shift; _service_cmd status "$1" ;;

        # ---- AIOS ----
        os-shell)
            _rlog "launching os-shell"
            OS_ROOT="$OS_ROOT" sh "$OS_ROOT/bin/os-shell"
            ;;
        aura.status)
            echo "=== AURA Status ==="
            cat "$OS_ROOT/proc/aura/bridge/status" 2>/dev/null || echo "Bridge: not initialized"
            echo ""
            echo "--- Memory index ---"
            cat "$OS_ROOT/etc/aura/memory.index" 2>/dev/null | head -20
            echo "==================="
            ;;
        aura.log)
            echo "=== AURA Audit Log (last 30 lines) ==="
            tail -n 30 "$AURA_LOG" 2>/dev/null || echo "(empty)"
            echo "======================================"
            ;;
        mode)
            shift
            case "$1" in
                operator|system|talk) AURA_MODE="$1"; _aura_say "Mode: $AURA_MODE" ;;
                *) echo "Modes: operator | system | talk" ;;
            esac
            ;;

        help)   _help ;;
        exit|quit)
            _aura_say "Goodbye."
            _rlog "real-shell exit"
            exit 0
            ;;
        "")     continue ;;

        *)
            # Try fuzzy correction
            suggestion=$(_fuzzy_real "$cmd")
            if [ -n "$suggestion" ]; then
                _rlog "TYPO: '$cmd' -> '$suggestion'"
                _aura_say "Unknown command '$cmd'. Auto-correcting to '$suggestion'..."
                shift
                _pending="$suggestion${*:+ $*}"
            else
                # Pass directly to real shell
                _rlog "EXEC: $line"
                eval "$line"
            fi
            ;;
    esac
done
