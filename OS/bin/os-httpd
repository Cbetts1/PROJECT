<script>
let _token = localStorage.getItem('aios_token') || '';
document.getElementById('token-field').value = _token;

function saveToken() {
  _token = document.getElementById('token-field').value.trim();
  localStorage.setItem('aios_token', _token);
  alert('Token saved.');
}

function headers() {
  const h = {'Content-Type':'application/json'};
  if (_token) h['X-API-Token'] = _token;
  return h;
}

async function fetchJSON(url) {
  const r = await fetch(url, {headers: headers()});
  if (!r.ok) throw new Error(r.status);
  return r.json();
}

async function loadHealth() {
  try {
    const d = await fetchJSON('/api/v1/health');
    document.getElementById('health-dot').className = 'dot';
    document.getElementById('health-text').textContent = 'Healthy';
    document.getElementById('health-time').textContent = d.time;
    document.getElementById('conn-status').textContent = '● Connected';
    document.getElementById('conn-status').style.color = 'var(--green)';
  } catch(e) {
    document.getElementById('health-dot').className = 'dot red';
    document.getElementById('health-text').textContent = 'Unreachable';
  }
}

async function loadStatus() {
  try {
    const d = await fetchJSON('/api/v1/status');
    document.getElementById('status-body').textContent =
      Object.entries(d).map(([k,v])=> k+': '+v).join('\\n');
    document.getElementById('sb-osroot').textContent = d.os_root || '(not set)';
  } catch(e) { document.getElementById('status-body').textContent = 'Error: '+e; }
}

async function loadServices() {
  try {
    const d = await fetchJSON('/api/v1/services');
    document.getElementById('services-body').textContent = d.services || '(no data)';
  } catch(e) { document.getElementById('services-body').textContent = 'Error: '+e; }
}

async function loadMetrics() {
  try {
    const d = await fetchJSON('/api/v1/metrics');
    const lines = [];
    if (d.mem_pct !== undefined) lines.push('Memory: '+d.mem_pct+'% used');
    if (d.disk_pct !== undefined) lines.push('Disk: '+d.disk_pct+'% used');
