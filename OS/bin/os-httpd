#!/usr/bin/env python3
# OS/bin/os-httpd — AIOS HTTP/HTTPS API Server
# © 2026 Chris Betts | AIOSCPU Official | AI-generated, fully legal
#
# Provides REST endpoints and a basic WebSocket upgrade path for OS management.
# Uses only Python standard library; no external dependencies required.
#
# Usage:
#   os-httpd [--port 8080] [--host 0.0.0.0] [--tls] [--cert cert.pem] [--key key.pem]
#   os-httpd --gen-cert               # generate a self-signed certificate
#   os-httpd --token-gen              # generate a new API token
#
# REST Endpoints (all require X-API-Token header unless --no-auth):
#   GET  /api/v1/status               OS state summary
#   GET  /api/v1/services             service health
#   GET  /api/v1/processes            process list (ps-style)
#   GET  /api/v1/metrics              resource metrics (cpu/mem/disk)
#   GET  /api/v1/logs[?source=os.log&tail=50]  read log tail
#   POST /api/v1/command              {"cmd": "..."} → run shell command
#   GET  /api/v1/events               Server-Sent Events (live log stream)
#   GET  /api/v1/health               liveness probe (unauthenticated)
#   GET  /ws                          WebSocket upgrade (echo test)

import argparse
import base64
import datetime
import hashlib
import http.server
import json
import os
import select
import socket
import ssl
import struct
import subprocess
import sys
import threading
import time

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
_HERE = os.path.dirname(os.path.abspath(__file__))
OS_ROOT = os.environ.get("OS_ROOT", os.path.dirname(_HERE))
AIOS_HOME = os.environ.get("AIOS_HOME", os.path.dirname(OS_ROOT))

TOKEN_FILE = os.path.join(OS_ROOT, "etc", "api.token")
CERT_FILE  = os.path.join(OS_ROOT, "etc", "ssl", "cert.pem")
KEY_FILE   = os.path.join(OS_ROOT, "etc", "ssl", "key.pem")
ACCESS_LOG = os.path.join(OS_ROOT, "var", "log", "httpd-access.log")
ERROR_LOG  = os.path.join(OS_ROOT, "var", "log", "httpd-error.log")
METRICS_LOG = os.path.join(OS_ROOT, "var", "log", "httpd-metrics.log")

os.makedirs(os.path.join(OS_ROOT, "etc", "ssl"), exist_ok=True)
os.makedirs(os.path.join(OS_ROOT, "var", "log"), exist_ok=True)


# ---------------------------------------------------------------------------
# Auth helpers
# ---------------------------------------------------------------------------

def load_token() -> str:
    if os.path.isfile(TOKEN_FILE):
        with open(TOKEN_FILE) as f:
            return f.read().strip()
    return ""


def gen_token() -> str:
    raw = os.urandom(32)
    token = base64.urlsafe_b64encode(raw).decode().rstrip("=")
    os.makedirs(os.path.dirname(TOKEN_FILE), exist_ok=True)
    with open(TOKEN_FILE, "w") as f:
        f.write(token + "\n")
    os.chmod(TOKEN_FILE, 0o600)
    return token


# ---------------------------------------------------------------------------
# TLS helpers
# ---------------------------------------------------------------------------

def gen_self_signed_cert(cert: str, key: str) -> bool:
    """Generate a self-signed certificate using openssl (if available)."""
    try:
        subprocess.check_call([
            "openssl", "req", "-x509", "-newkey", "rsa:2048",
            "-keyout", key, "-out", cert,
            "-days", "3650", "-nodes",
            "-subj", "/CN=aios-localhost/O=AIOS/C=US"
        ], stderr=subprocess.DEVNULL)
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


# ---------------------------------------------------------------------------
# OS helpers (run commands inside the OS_ROOT environment)
# ---------------------------------------------------------------------------

def _run(cmd: list, timeout: int = 10) -> str:
    env = dict(os.environ, OS_ROOT=OS_ROOT, AIOS_HOME=AIOS_HOME)
    try:
        return subprocess.check_output(
            cmd, stderr=subprocess.STDOUT, text=True, env=env, timeout=timeout
        ).strip()
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired,
            FileNotFoundError) as e:
        return f"[error] {e}"


def _read_state() -> dict:
    state: dict = {}
    sf = os.path.join(OS_ROOT, "proc", "os.state")
    if os.path.isfile(sf):
        with open(sf) as f:
            for line in f:
                if "=" in line:
                    k, _, v = line.strip().partition("=")
                    state[k.strip()] = v.strip()
    return state


def _read_log_tail(source: str = "os.log", n: int = 50) -> str:
    log_path = os.path.join(OS_ROOT, "var", "log", source)
    if not os.path.isfile(log_path):
        return f"[log not found: {source}]"
    with open(log_path, errors="replace") as f:
        lines = f.readlines()
    return "".join(lines[-n:]).rstrip()


def _collect_metrics() -> dict:
    metrics: dict = {"timestamp": datetime.datetime.utcnow().isoformat() + "Z"}
    if os.path.isfile("/proc/meminfo"):
        with open("/proc/meminfo") as f:
            raw = {l.split(":")[0]: int(l.split()[1])
                   for l in f if ":" in l and l.split()[-1] == "kB"}
        total = raw.get("MemTotal", 0)
        avail = raw.get("MemAvailable", raw.get("MemFree", 0))
        metrics["mem_total_kb"] = total
        metrics["mem_used_kb"]  = total - avail
        metrics["mem_pct"]      = round((total - avail) * 100 / total, 1) if total else 0
    try:
        df_out = subprocess.check_output(["df", "-k", OS_ROOT],
                                         text=True, stderr=subprocess.DEVNULL)
        parts = df_out.strip().split("\n")[-1].split()
        metrics["disk_total_kb"] = int(parts[1])
        metrics["disk_used_kb"]  = int(parts[2])
        metrics["disk_pct"]      = int(parts[4].rstrip("%"))
    except Exception:
        pass
    metrics["uptime_raw"] = _run(["uptime"])
    return metrics


# ---------------------------------------------------------------------------
# WebSocket framing
# ---------------------------------------------------------------------------

_WS_MAGIC = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"


def _ws_accept(key: str) -> str:
    combined = (key + _WS_MAGIC).encode()
    return base64.b64encode(hashlib.sha1(combined).digest()).decode()


def _ws_encode(message: str) -> bytes:
    payload = message.encode("utf-8")
    n = len(payload)
    if n < 126:
        header = bytes([0x81, n])
    elif n < 65536:
        header = struct.pack(">BBH", 0x81, 126, n)
    else:
        header = struct.pack(">BBQ", 0x81, 127, n)
    return header + payload


def _ws_decode(data: bytes):
    if len(data) < 2:
        return None
    b1, b2 = data[0], data[1]
    masked = (b2 >> 7) & 1
    plen = b2 & 0x7F
    offset = 2
    if plen == 126:
        plen = struct.unpack(">H", data[2:4])[0]
        offset = 4
    elif plen == 127:
        plen = struct.unpack(">Q", data[2:10])[0]
        offset = 10
    if masked:
        mask = data[offset:offset + 4]
        offset += 4
        payload = bytes(data[offset + i] ^ mask[i % 4] for i in range(plen))
    else:
        payload = data[offset:offset + plen]
    return payload.decode("utf-8", errors="replace")


# ---------------------------------------------------------------------------
# HTTP request handler
# ---------------------------------------------------------------------------

class AIOSHandler(http.server.BaseHTTPRequestHandler):

    API_TOKEN: str = ""
    NO_AUTH:   bool = False

    # ------------------------------------------------------------------
    # Logging overrides
    # ------------------------------------------------------------------

    def log_message(self, fmt, *args):
        ts = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
        entry = f"[{ts}] {self.address_string()} {fmt % args}\n"
        with open(ACCESS_LOG, "a") as f:
            f.write(entry)

    def log_error(self, fmt, *args):
        ts = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
        entry = f"[{ts}] ERROR {self.address_string()} {fmt % args}\n"
        with open(ERROR_LOG, "a") as f:
            f.write(entry)

    # ------------------------------------------------------------------
    # Auth
    # ------------------------------------------------------------------

    def _is_authenticated(self) -> bool:
        if self.NO_AUTH:
            return True
        if not self.API_TOKEN:
            return True  # no token configured → open
        token = self.headers.get("X-API-Token", "")
        return token == self.API_TOKEN

    # ------------------------------------------------------------------
    # Response helpers
    # ------------------------------------------------------------------

    def _json(self, code: int, data: object) -> None:
        body = json.dumps(data, indent=2).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("X-AIOS-Version", "0.1")
        self.end_headers()
        self.wfile.write(body)

    def _text(self, code: int, text: str) -> None:
        body = text.encode()
        self.send_response(code)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _unauthorized(self) -> None:
        self._json(401, {"error": "Unauthorized", "hint": "Set X-API-Token header"})

    # ------------------------------------------------------------------
    # Routing
    # ------------------------------------------------------------------

    def do_GET(self) -> None:
        path = self.path.split("?")[0].rstrip("/")
        query = self.path[len(path):]

        # Liveness (unauthenticated)
        if path == "/api/v1/health":
            self._json(200, {"status": "ok", "time": datetime.datetime.utcnow().isoformat() + "Z"})
            return

        # WebSocket upgrade
        if path == "/ws" and self.headers.get("Upgrade", "").lower() == "websocket":
            self._ws_handshake()
            return

        # Server-Sent Events
        if path == "/api/v1/events":
            if not self._is_authenticated():
                self._unauthorized(); return
            self._sse_stream()
            return

        if not self._is_authenticated():
            self._unauthorized(); return

        if path == "/api/v1/status":
            state = _read_state()
            state["server_time"] = datetime.datetime.utcnow().isoformat() + "Z"
            self._json(200, state)

        elif path == "/api/v1/services":
            out = _run(["sh", os.path.join(OS_ROOT, "bin", "os-service-status")])
            self._json(200, {"services": out})

        elif path == "/api/v1/processes":
            out = _run(["ps", "aux"])
            self._json(200, {"processes": out})

        elif path == "/api/v1/metrics":
            m = _collect_metrics()
            with open(METRICS_LOG, "a") as f:
                f.write(json.dumps(m) + "\n")
            self._json(200, m)

        elif path == "/api/v1/logs":
            params = {}
            if "?" in self.path:
                for part in self.path.split("?", 1)[1].split("&"):
                    if "=" in part:
                        k, _, v = part.partition("=")
                        params[k] = v
            source = params.get("source", "os.log")
            tail_n = int(params.get("tail", "50"))
            content = _read_log_tail(source, tail_n)
            self._json(200, {"source": source, "tail": tail_n, "content": content})

        else:
            self._json(404, {"error": "Not Found", "path": path})

    def do_POST(self) -> None:
        path = self.path.rstrip("/")
        if not self._is_authenticated():
            self._unauthorized(); return

        if path == "/api/v1/command":
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            try:
                payload = json.loads(body)
            except json.JSONDecodeError:
                self._json(400, {"error": "Invalid JSON"}); return
            cmd_str = str(payload.get("cmd", "")).strip()
            if not cmd_str:
                self._json(400, {"error": "cmd field required"}); return
            # Run through os-shell's non-interactive mode for safety
            os_shell = os.path.join(OS_ROOT, "bin", "os-shell")
            env = dict(os.environ, OS_ROOT=OS_ROOT, AIOS_HOME=AIOS_HOME)
            try:
                out = subprocess.check_output(
                    ["sh", os_shell],
                    input=cmd_str, text=True,
                    stderr=subprocess.STDOUT, env=env, timeout=15
                ).strip()
                self._json(200, {"cmd": cmd_str, "output": out})
            except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
                self._json(500, {"error": str(e)})
        else:
            self._json(404, {"error": "Not Found"})

    # ------------------------------------------------------------------
    # Server-Sent Events
    # ------------------------------------------------------------------

    def _sse_stream(self) -> None:
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.end_headers()
        log_path = os.path.join(OS_ROOT, "var", "log", "aura.log")
        pos = 0
        if os.path.isfile(log_path):
            with open(log_path) as f:
                f.seek(0, 2)
                pos = f.tell()
        try:
            for _ in range(600):  # ~60 s max
                if os.path.isfile(log_path):
                    with open(log_path, errors="replace") as f:
                        f.seek(pos)
                        new_data = f.read()
                        pos = f.tell()
                    if new_data:
                        for line in new_data.splitlines():
                            msg = f"data: {line}\n\n"
                            self.wfile.write(msg.encode())
                        self.wfile.flush()
                time.sleep(0.1)
        except (BrokenPipeError, ConnectionResetError):
            pass

    # ------------------------------------------------------------------
    # WebSocket
    # ------------------------------------------------------------------

    def _ws_handshake(self) -> None:
        key = self.headers.get("Sec-WebSocket-Key", "")
        accept = _ws_accept(key)
        self.send_response(101)
        self.send_header("Upgrade", "websocket")
        self.send_header("Connection", "Upgrade")
        self.send_header("Sec-WebSocket-Accept", accept)
        self.end_headers()
        self.wfile.flush()
        conn = self.request
        conn.settimeout(30)
        try:
            while True:
                rlist, _, _ = select.select([conn], [], [], 30)
                if not rlist:
                    break
                data = conn.recv(4096)
                if not data:
                    break
                msg = _ws_decode(data)
                if msg is not None:
                    echo = json.dumps({"echo": msg, "time": time.time()})
                    conn.sendall(_ws_encode(echo))
        except (OSError, ssl.SSLError):
            pass


# ---------------------------------------------------------------------------
# Server startup
# ---------------------------------------------------------------------------

def make_server(host: str, port: int, use_tls: bool,
                cert: str, key: str) -> http.server.HTTPServer:
    server = http.server.HTTPServer((host, port), AIOSHandler)
    if use_tls:
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain(certfile=cert, keyfile=key)
        server.socket = ctx.wrap_socket(server.socket, server_side=True)
    return server


def main() -> None:
    parser = argparse.ArgumentParser(description="AIOS HTTP API Server")
    parser.add_argument("--host",     default="0.0.0.0")
    parser.add_argument("--port",     type=int, default=8080)
    parser.add_argument("--tls",      action="store_true")
    parser.add_argument("--cert",     default=CERT_FILE)
    parser.add_argument("--key",      default=KEY_FILE)
    parser.add_argument("--no-auth",  action="store_true")
    parser.add_argument("--gen-cert", action="store_true",
                        help="Generate self-signed cert and exit")
    parser.add_argument("--token-gen", action="store_true",
                        help="Generate API token and exit")
    args = parser.parse_args()

    if args.gen_cert:
        if gen_self_signed_cert(args.cert, args.key):
            print(f"Certificate generated: {args.cert}")
            print(f"Private key:          {args.key}")
        else:
            print("ERROR: openssl not found; cannot generate certificate", file=sys.stderr)
            sys.exit(1)
        return

    if args.token_gen:
        token = gen_token()
        print(f"API token generated: {token}")
        print(f"Saved to: {TOKEN_FILE}")
        return

    AIOSHandler.API_TOKEN = load_token()
    AIOSHandler.NO_AUTH   = args.no_auth

    if args.tls and not (os.path.isfile(args.cert) and os.path.isfile(args.key)):
        print("TLS requested but cert/key not found. Generating self-signed cert ...")
        if not gen_self_signed_cert(args.cert, args.key):
            print("ERROR: could not generate cert (openssl required)", file=sys.stderr)
            sys.exit(1)

    scheme = "https" if args.tls else "http"
    print(f"[os-httpd] Starting AIOS API server on {scheme}://{args.host}:{args.port}/")
    print(f"[os-httpd] OS_ROOT  : {OS_ROOT}")
    print(f"[os-httpd] Auth     : {'disabled' if args.no_auth else ('token' if AIOSHandler.API_TOKEN else 'open (no token set)')}")
    print(f"[os-httpd] TLS      : {'enabled' if args.tls else 'disabled'}")
    print(f"[os-httpd] Log      : {ACCESS_LOG}")

    server = make_server(args.host, args.port, args.tls, args.cert, args.key)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n[os-httpd] Shutting down.")
        server.server_close()


if __name__ == "__main__":
    main()
