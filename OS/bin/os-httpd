# ---------------------------------------------------------------------------
# HTTP request handler
# ---------------------------------------------------------------------------

class AIOSHandler(http.server.BaseHTTPRequestHandler):

    API_TOKEN: str = ""
    NO_AUTH:   bool = False

    # ------------------------------------------------------------------
    # Logging overrides
    # ------------------------------------------------------------------

    def log_message(self, fmt, *args):
        ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        entry = f"[{ts}] {self.address_string()} {fmt % args}\n"
        with open(ACCESS_LOG, "a") as f:
            f.write(entry)

    def log_error(self, fmt, *args):
        ts = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        entry = f"[{ts}] ERROR {self.address_string()} {fmt % args}\n"
        with open(ERROR_LOG, "a") as f:
            f.write(entry)

    # ------------------------------------------------------------------
    # Auth
    # ------------------------------------------------------------------

    def _is_authenticated(self) -> bool:
        if self.NO_AUTH:
            return True
        if not self.API_TOKEN:
            return True  # no token configured → open
        token = self.headers.get("X-API-Token", "")
        return token == self.API_TOKEN

    # ------------------------------------------------------------------
    # Response helpers
    # ------------------------------------------------------------------

    def _json(self, code: int, data: object) -> None:
        body = json.dumps(data, indent=2).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("X-AIOS-Version", "0.1")
        self.end_headers()
        self.wfile.write(body)

    def _text(self, code: int, text: str) -> None:
        body = text.encode()
        self.send_response(code)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _unauthorized(self) -> None:
        self._json(401, {"error": "Unauthorized", "hint": "Set X-API-Token header"})

    # ------------------------------------------------------------------
    # Routing
    # ------------------------------------------------------------------

    def do_GET(self) -> None:
        path = self.path.split("?")[0].rstrip("/")
        query = self.path[len(path):]

        # Liveness (unauthenticated)
        if path == "/api/v1/health":
            self._json(200, {"status": "ok", "time": datetime.datetime.now(datetime.timezone.utc).isoformat().replace("+00:00","Z")})
            return

        # WebSocket upgrade
        if path == "/ws" and self.headers.get("Upgrade", "").lower() == "websocket":
            self._ws_handshake()
            return

        # Server-Sent Events
        if path == "/api/v1/events":
            if not self._is_authenticated():
                self._unauthorized(); return
            self._sse_stream()
            return

        # Web dashboard (unauthenticated static SPA)
        if path in ("", "/"):
            self._serve_dashboard()
            return

        if not self._is_authenticated():
            self._unauthorized(); return

        if path == "/api/v1/status":
            state = _read_state()
            state["server_time"] = datetime.datetime.now(datetime.timezone.utc).isoformat().replace("+00:00","Z")
            self._json(200, state)

        elif path == "/api/v1/services":
            out = _run(["sh", os.path.join(OS_ROOT, "bin", "os-service-status")])
            self._json(200, {"services": out})

        elif path == "/api/v1/processes":
            out = _run(["ps", "aux"])
            self._json(200, {"processes": out})

        elif path == "/api/v1/metrics":
            m = _collect_metrics()
            with open(METRICS_LOG, "a") as f:
                f.write(json.dumps(m) + "\n")
            self._json(200, m)

        elif path == "/api/v1/logs":
            params = {}
            if "?" in self.path:
                for part in self.path.split("?", 1)[1].split("&"):
                    if "=" in part:
                        k, _, v = part.partition("=")
                        params[k] = v
            source = params.get("source", "os.log")
            tail_n = int(params.get("tail", "50"))
            content = _read_log_tail(source, tail_n)
            self._json(200, {"source": source, "tail": tail_n, "content": content})

        else:
            self._json(404, {"error": "Not Found", "path": path})

    def do_POST(self) -> None:
        path = self.path.rstrip("/")
        if not self._is_authenticated():
            self._unauthorized(); return

        if path == "/api/v1/command":
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            try:
                payload = json.loads(body)
            except json.JSONDecodeError:
                self._json(400, {"error": "Invalid JSON"}); return
            cmd_str = str(payload.get("cmd", "")).strip()
            if not cmd_str:
                self._json(400, {"error": "cmd field required"}); return
            # Run through os-shell's non-interactive mode for safety
            os_shell = os.path.join(OS_ROOT, "bin", "os-shell")
            env = dict(os.environ, OS_ROOT=OS_ROOT, AIOS_HOME=AIOS_HOME)
            try:
                out = subprocess.check_output(
                    ["sh", os_shell],
                    input=cmd_str, text=True,
                    stderr=subprocess.STDOUT, env=env, timeout=15
                ).strip()
                self._json(200, {"cmd": cmd_str, "output": out})
            except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
                self._json(500, {"error": str(e)})
        else:
            self._json(404, {"error": "Not Found"})

    # ------------------------------------------------------------------
    # Web Dashboard (static SPA)
    # ------------------------------------------------------------------

    def _serve_dashboard(self) -> None:
        """Serve the AIOS-Lite single-page web dashboard."""
        html = _DASHBOARD_HTML
        body = html.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    # ------------------------------------------------------------------
    # Server-Sent Events
    # ------------------------------------------------------------------

    def _sse_stream(self) -> None:
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.end_headers()
        log_path = os.path.join(OS_ROOT, "var", "log", "aura.log")
        pos = 0
        if os.path.isfile(log_path):
            with open(log_path) as f:
                f.seek(0, 2)
                pos = f.tell()
        try:
            for _ in range(600):  # ~60 s max
                if os.path.isfile(log_path):
                    with open(log_path, errors="replace") as f:
                        f.seek(pos)
                        new_data = f.read()
                        pos = f.tell()
                    if new_data:
                        for line in new_data.splitlines():
                            msg = f"data: {line}\n\n"
                            self.wfile.write(msg.encode())
                        self.wfile.flush()
                time.sleep(0.1)
        except (BrokenPipeError, ConnectionResetError):
            pass

    # ------------------------------------------------------------------
    # WebSocket
    # ------------------------------------------------------------------

    def _ws_handshake(self) -> None:
        key = self.headers.get("Sec-WebSocket-Key", "")
        accept = _ws_accept(key)
        self.send_response(101)
        self.send_header("Upgrade", "websocket")
        self.send_header("Connection", "Upgrade")
        self.send_header("Sec-WebSocket-Accept", accept)
        self.end_headers()
        self.wfile.flush()
        conn = self.request
        conn.settimeout(30)
        try:
            while True:
                rlist, _, _ = select.select([conn], [], [], 30)
                if not rlist:
                    break
                data = conn.recv(4096)
                if not data:
                    break
                msg = _ws_decode(data)
                if msg is not None:
                    echo = json.dumps({"echo": msg, "time": time.time()})
                    conn.sendall(_ws_encode(echo))
        except (OSError, ssl.SSLError):
            pass


# ---------------------------------------------------------------------------
# Server startup
# ---------------------------------------------------------------------------

def make_server(host: str, port: int, use_tls: bool,
                cert: str, key: str) -> http.server.HTTPServer:
    server = http.server.HTTPServer((host, port), AIOSHandler)
    if use_tls:
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        # Enforce minimum TLS 1.2; disallow SSLv2/3, TLS 1.0, and TLS 1.1
        ctx.minimum_version = ssl.TLSVersion.TLSv1_2
        ctx.load_cert_chain(certfile=cert, keyfile=key)
        server.socket = ctx.wrap_socket(server.socket, server_side=True)
    return server


def main() -> None:
    parser = argparse.ArgumentParser(description="AIOS HTTP API Server")
    parser.add_argument("--host",     default="0.0.0.0")
    parser.add_argument("--port",     type=int, default=8080)
    parser.add_argument("--tls",      action="store_true")
    parser.add_argument("--cert",     default=CERT_FILE)
    parser.add_argument("--key",      default=KEY_FILE)
    parser.add_argument("--no-auth",  action="store_true")
    parser.add_argument("--gen-cert", action="store_true",
                        help="Generate self-signed cert and exit")
    parser.add_argument("--token-gen", action="store_true",
                        help="Generate API token and exit")
    args = parser.parse_args()

    if args.gen_cert:
        if gen_self_signed_cert(args.cert, args.key):
            print(f"Certificate generated: {args.cert}")
            print(f"Private key:          {args.key}")
        else:
            print("ERROR: openssl not found; cannot generate certificate", file=sys.stderr)
            sys.exit(1)
        return

    if args.token_gen:
        token = gen_token()
        print(f"API token generated: {token}")
        print(f"Saved to: {TOKEN_FILE}")
        return

    AIOSHandler.API_TOKEN = load_token()
    AIOSHandler.NO_AUTH   = args.no_auth

    if args.tls and not (os.path.isfile(args.cert) and os.path.isfile(args.key)):
        print("TLS requested but cert/key not found. Generating self-signed cert ...")
        if not gen_self_signed_cert(args.cert, args.key):
            print("ERROR: could not generate cert (openssl required)", file=sys.stderr)
            sys.exit(1)

    scheme = "https" if args.tls else "http"
    print(f"[os-httpd] Starting AIOS API server on {scheme}://{args.host}:{args.port}/")
    print(f"[os-httpd] OS_ROOT  : {OS_ROOT}")
    print(f"[os-httpd] Auth     : {'disabled' if args.no_auth else ('token' if AIOSHandler.API_TOKEN else 'open (no token set)')}")
    print(f"[os-httpd] TLS      : {'enabled' if args.tls else 'disabled'}")
    print(f"[os-httpd] Log      : {ACCESS_LOG}")

    server = make_server(args.host, args.port, args.tls, args.cert, args.key)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n[os-httpd] Shutting down.")
        server.server_close()


if __name__ == "__main__":
    main()
