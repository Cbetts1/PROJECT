#!/bin/sh
# os-kernelctl — Control and query the logical kernel surface at $OS_ROOT/proc/os
# Sections: state, services, ai, bridge, health, logs

OS_ROOT="${OS_ROOT:-/}"
STATE="$OS_ROOT/var/service"
PIDFILE="$STATE/os-kernel.pid"
PROCDIR="$OS_ROOT/proc/os"
PROCFILE="$PROCDIR/state"
INITD="$OS_ROOT/etc/init.d/os-kernel"
LOG="$OS_ROOT/var/log/os.log"

cmd="${1:-help}"
shift

_kernel_uptime() {
    if [ -f "$STATEFILE" ]; then
        boot_time=$(awk -F= '/^boot_time=/ {print $2}' "$STATEFILE" 2>/dev/null)
        if [ -n "$boot_time" ] && [ "$boot_time" -gt 0 ] 2>/dev/null; then
            now=$(date +%s)
            elapsed=$(( now - boot_time ))
            days=$(( elapsed / 86400 ))
            hrs=$(( (elapsed % 86400) / 3600 ))
            mins=$(( (elapsed % 3600) / 60 ))
            secs=$(( elapsed % 60 ))
            printf 'Uptime: %dd %02dh %02dm %02ds (boot_time=%s)\n' \
                "$days" "$hrs" "$mins" "$secs" "$boot_time"
        else
            echo "Uptime: unknown (boot_time not set)"
        fi
    else
        echo "Uptime: state file not found"
    fi
}

_kernel_metrics() {
    echo "=== Kernel Metrics ==="
    _kernel_uptime
    echo ""
    # CPU load
    if [ -f /proc/loadavg ]; then
        read -r la1 la5 la15 _ < /proc/loadavg
        printf 'Load avg:  1m=%-6s 5m=%-6s 15m=%s\n' "$la1" "$la5" "$la15"
    fi
    # Memory
    if [ -f /proc/meminfo ]; then
        mem_total=$(awk '/^MemTotal:/ {print $2}' /proc/meminfo)
        mem_avail=$(awk '/^MemAvailable:/ {print $2}' /proc/meminfo)
        mem_used=$(( mem_total - mem_avail ))
        printf 'Memory:    total=%dMB used=%dMB avail=%dMB\n' \
            "$(( mem_total / 1024 ))" \
            "$(( mem_used / 1024 ))" \
            "$(( mem_avail / 1024 ))"
    else
        printf 'Memory:    (unavailable)\n'
    fi
    # Disk usage under OS_ROOT
    du_out=$(df -h "$OS_ROOT" 2>/dev/null | tail -1)
    printf 'Disk:      %s\n' "$du_out"
    echo "======================"
}

_kernel_proc_dump() {
    fmt="${1:-text}"
    case "$fmt" in
        json)
            echo "{"
            awk -F= '{
                gsub(/"/, "\\\"", $2)
                printf "  \"%s\": \"%s\",\n", $1, $2
            }' "$PROCFILE" 2>/dev/null | sed '$s/,$//'
            boot_time=$(awk -F= '/^boot_time=/ {print $2}' "$STATEFILE" 2>/dev/null || echo 0)
            kernel_pid=$(awk -F= '/^kernel_pid=/ {print $2}' "$STATEFILE" 2>/dev/null || echo 0)
            runlevel=$(awk -F= '/^runlevel=/ {print $2}' "$STATEFILE" 2>/dev/null || echo 0)
            printf '  "boot_time": "%s",\n' "$boot_time"
            printf '  "kernel_pid": "%s",\n' "$kernel_pid"
            printf '  "runlevel": "%s"\n' "$runlevel"
            echo "}"
            ;;
        *)
            echo "=== Kernel Personality ==="
            cat "$PROCFILE" 2>/dev/null || echo "(none)"
            echo ""
            echo "=== Kernel State ==="
            cat "$STATEFILE" 2>/dev/null || echo "(none)"
            echo "===================="
            ;;
    esac
}

case "$cmd" in
  status)
    echo "Kernel Daemon Status"
    echo "===================="
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        if [ -d "/proc/$pid" ]; then
            echo "Running: yes"
            echo "PID:      $pid"
        else
            echo "Running: no (stale pid $pid)"
        fi
    else
        echo "Running: no"
    fi

    echo
    echo "Kernel State:"
    if [ -f "$PROCDIR/state" ]; then
        cat "$PROCDIR/state"
    else
        echo "(state not initialised)"
    fi
    ;;

  restart)
    echo "[os-kernelctl] Restarting kernel daemon..."
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null
        rm -f "$PIDFILE"
    fi
    sh "$INITD" start
    echo "[os-kernelctl] Restart complete."
    ;;

  reload)
    echo "[os-kernelctl] Reloading kernel personality..."
    if [ -f "$PROCDIR/state" ]; then
        . "$PROCDIR/state"
        echo "Loaded OS personality:"
        echo "  Name:    ${OS_NAME:-unknown}"
        echo "  Version: ${OS_VERSION:-unknown}"
        echo "  Vendor:  ${OS_VENDOR:-unknown}"
    else
        echo "No kernel state found at $PROCDIR/state."
    fi
    ;;

  info)
    echo "Kernel Personality Info"
    echo "======================="
    if [ -f "$PROCDIR/state" ]; then
        cat "$PROCDIR/state"
    else
        echo "(none)"
    fi
    ;;

  list)
    echo "proc/os sections:"
    if [ -d "$PROCDIR" ]; then
        for f in "$PROCDIR"/*; do
            [ -f "$f" ] && echo "  $(basename "$f")"
        done
    else
        echo "  (proc/os directory not found)"
    fi
    ;;

  query)
    section="${1:-state}"
    target="$PROCDIR/$section"
    if [ -f "$target" ]; then
        echo "=== proc/os/$section ==="
        cat "$target"
    else
        echo "Section '$section' not found in $PROCDIR" >&2
        exit 1
    fi
    ;;

  *)
    echo "Usage: os-kernelctl {status|restart|reload|info|list|query <section>}"
    echo "Sections: state  services  ai  bridge  health  logs"
    ;;
esac
