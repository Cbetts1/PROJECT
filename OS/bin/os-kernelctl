#!/bin/sh
# os-kernelctl — Control and query the logical kernel surface at $OS_ROOT/proc/os
# Sections: state, services, ai, bridge, health, logs

OS_ROOT="${OS_ROOT:-/}"
STATE="$OS_ROOT/var/service"
PIDFILE="$STATE/os-kernel.pid"
PROCDIR="$OS_ROOT/proc/os"
INITD="$OS_ROOT/etc/init.d/os-kernel"

cmd="${1:-help}"
shift

case "$cmd" in
  status)
    echo "Kernel Daemon Status"
    echo "===================="
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        if [ -d "/proc/$pid" ]; then
            echo "Running: yes"
            echo "PID:      $pid"
        else
            echo "Running: no (stale pid $pid)"
        fi
    else
        echo "Running: no"
    fi

    echo
    echo "Kernel State:"
    if [ -f "$PROCDIR/state" ]; then
        cat "$PROCDIR/state"
    else
        echo "(state not initialised)"
    fi
    ;;

  restart)
    echo "[os-kernelctl] Restarting kernel daemon..."
    if [ -f "$PIDFILE" ]; then
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null
        rm -f "$PIDFILE"
    fi
    sh "$INITD" start
    echo "[os-kernelctl] Restart complete."
    ;;

  reload)
    echo "[os-kernelctl] Reloading kernel personality..."
    if [ -f "$PROCDIR/state" ]; then
        . "$PROCDIR/state"
        echo "Loaded OS personality:"
        echo "  Name:    ${OS_NAME:-unknown}"
        echo "  Version: ${OS_VERSION:-unknown}"
        echo "  Vendor:  ${OS_VENDOR:-unknown}"
    else
        echo "No kernel state found at $PROCDIR/state."
    fi
    ;;

  info)
    echo "Kernel Personality Info"
    echo "======================="
    if [ -f "$PROCDIR/state" ]; then
        cat "$PROCDIR/state"
    else
        echo "(none)"
    fi
    ;;

  list)
    echo "proc/os sections:"
    if [ -d "$PROCDIR" ]; then
        for f in "$PROCDIR"/*; do
            [ -f "$f" ] && echo "  $(basename "$f")"
        done
    else
        echo "  (proc/os directory not found)"
    fi
    ;;

  query)
    section="${1:-state}"
    target="$PROCDIR/$section"
    if [ -f "$target" ]; then
        echo "=== proc/os/$section ==="
        cat "$target"
    else
        echo "Section '$section' not found in $PROCDIR" >&2
        exit 1
    fi
    ;;

  *)
    echo "Usage: os-kernelctl {status|restart|reload|info|list|query <section>}"
    echo "Sections: state  services  ai  bridge  health  logs"
    ;;
esac
