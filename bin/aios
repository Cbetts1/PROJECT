#!/usr/bin/env bash
# bin/aios — AIOS interactive AI shell
#
# Dual-shell design:
#   - This AI shell handles AIOS commands (fs.*, proc.*, net.*), typo
#     correction, and natural-language AI queries.
#   - Type 'sys' or 'sys <cmd>' to drop into the real OS shell (bin/aios-sys).
#
# Usage:
#   ./bin/aios
#   ./run.sh

AIOS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export AIOS_ROOT

# ---------------------------------------------------------------------------
# Load all aura modules (include guards make re-sourcing safe)
# ---------------------------------------------------------------------------
# shellcheck source=lib/aura-core.sh
. "${AIOS_ROOT}/lib/aura-core.sh"
# shellcheck source=lib/aura-security.sh
. "${AIOS_ROOT}/lib/aura-security.sh"
# shellcheck source=lib/aura-fs.sh
. "${AIOS_ROOT}/lib/aura-fs.sh"
# shellcheck source=lib/aura-proc.sh
. "${AIOS_ROOT}/lib/aura-proc.sh"
# shellcheck source=lib/aura-net.sh
. "${AIOS_ROOT}/lib/aura-net.sh"
# shellcheck source=lib/aura-typo.sh
. "${AIOS_ROOT}/lib/aura-typo.sh"
# shellcheck source=lib/aura-llama.sh
. "${AIOS_ROOT}/lib/aura-llama.sh"
# shellcheck source=lib/aura-ai.sh
. "${AIOS_ROOT}/lib/aura-ai.sh"

# ---------------------------------------------------------------------------
# Readline history
# ---------------------------------------------------------------------------
AIOS_HISTFILE="${AIOS_HISTFILE:-${AIOS_ROOT}/var/run/aios_history}"
mkdir -p "$(dirname "${AIOS_HISTFILE}")"
HISTFILE="${AIOS_HISTFILE}"
HISTSIZE=500
HISTFILESIZE=1000
set -o history 2>/dev/null || true   # enable history in non-interactive mode

prompt="aios> "

# ---------------------------------------------------------------------------
# Setup status check — shown once at startup to help users get configured
# ---------------------------------------------------------------------------
_aios_setup_status() {
    local ok=1

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AIOS — AI Operating System Shell  v1.0 (Aurora)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # OS jail
    printf "  OS jail  : %s\n" "${OS_ROOT}"

    # AI backend
    local backend="${AI_BACKEND:-mock}"
    if [[ "${backend}" == "mock" ]]; then
        printf "  AI mode  : built-in (rule-based) — no LLM loaded\n"
        ok=0
    else
        printf "  AI mode  : %s\n" "${backend}"
    fi

    # LLM model file — check OS_ROOT/llama_model/ first (autodetect path),
    # then AIOS_ROOT/llama_model/ as a secondary location.
    local model_found=0
    for _mdir in "${OS_ROOT}/llama_model" "${AIOS_ROOT}/llama_model"; do
        if [[ -d "${_mdir}" ]]; then
            while IFS= read -r -d '' f; do
                model_found=1
                printf "  Model    : %s\n" "$(basename "${f}")"
                break
            done < <(find "${_mdir}" -maxdepth 1 -name "*.gguf" -print0 2>/dev/null)
        fi
        [[ "${model_found}" -eq 1 ]] && break
    done
    if [[ "${model_found}" -eq 0 ]]; then
        printf "  Model    : AI offline, fallback mode (see docs/AI_MODEL_SETUP.md)\n"
        ok=0
    fi

    # llama binary
    local llama_bin=""
    for _b in llama-cli llama llama.cpp main; do
        if command -v "${_b}" &>/dev/null || \
           [[ -x "${AIOS_ROOT}/build/llama.cpp/build/bin/${_b}" ]]; then
            llama_bin="${_b}"
            break
        fi
    done
    if [[ -z "${llama_bin}" ]]; then
        printf "  llama    : not built (run: bash build/build.sh --target hosted)\n"
        ok=0
    else
        printf "  llama    : %s\n" "${llama_bin}"
    fi

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    if [[ "${ok}" -eq 0 ]]; then
        echo "  💡 Setup tip: type  'ask how do I set up the AI'  to get"
        echo "                guided instructions, or see docs/AI_MODEL_SETUP.md"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi

    echo "  Type 'help' for commands, 'exit' to quit."
    echo
}

# ---------------------------------------------------------------------------
# Built-in: status — show live kernel/AI state
# ---------------------------------------------------------------------------
_aios_status() {
    local state_file="${OS_ROOT}/proc/os.state"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AIOS System Status"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  AI backend : %s\n" "${AI_BACKEND:-mock}"
    printf "  OS jail    : %s\n" "${OS_ROOT}"
    printf "  AIOS root  : %s\n" "${AIOS_ROOT}"
    printf "  Log file   : %s\n" "${AIOS_LOG_FILE}"
    if [[ -f "${state_file}" ]]; then
        local bt
        bt=$(grep -m1 "^boot_time=" "${state_file}" 2>/dev/null | cut -d= -f2 || echo "unknown")
        if [[ "${bt}" =~ ^[0-9]+$ ]]; then
            local now; now=$(date +%s)
            local uptime=$(( now - bt ))
            printf "  Uptime     : %ds\n" "${uptime}"
        fi
        local kpid
        kpid=$(grep -m1 "^kernel_pid=" "${state_file}" 2>/dev/null | cut -d= -f2 || echo "?")
        printf "  Kernel PID : %s\n" "${kpid}"
    fi
    local log_lines=0
    [[ -f "${AIOS_LOG_FILE}" ]] && log_lines=$(wc -l < "${AIOS_LOG_FILE}" 2>/dev/null || echo 0)
    printf "  Log lines  : %s\n" "${log_lines}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# ---------------------------------------------------------------------------
# Built-in: sysinfo — summary of host + OS environment
# ---------------------------------------------------------------------------
_aios_sysinfo() {
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AIOS System Information"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  OS name    : AIOS Aurora v1.0\n"
    printf "  Host OS    : %s %s\n" "$(uname -s)" "$(uname -r)"
    printf "  Hostname   : %s\n" "$(hostname 2>/dev/null || echo unknown)"
    printf "  User       : %s\n" "${USER:-${LOGNAME:-unknown}}"
    if command -v free &>/dev/null; then
        local mem
        mem=$(free -h 2>/dev/null | awk '/^Mem:/ {print $2 " total, " $3 " used"}')
        printf "  Memory     : %s\n" "${mem}"
    fi
    if command -v df &>/dev/null; then
        local disk
        disk=$(df -h "${AIOS_ROOT}" 2>/dev/null | awk 'NR==2 {print $4 " free of " $2}')
        printf "  Disk (root): %s\n" "${disk}"
    fi
    printf "  Bash ver   : %s\n" "${BASH_VERSION}"
    if command -v python3 &>/dev/null; then
        printf "  Python     : %s\n" "$(python3 --version 2>&1)"
    fi
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# ---------------------------------------------------------------------------
# Built-in: log.tail — show last N lines of aios.log
# ---------------------------------------------------------------------------
_aios_log_tail() {
    local n="${1:-20}"
    if [[ ! "${n}" =~ ^[0-9]+$ ]]; then n=20; fi
    echo "--- last ${n} lines of ${AIOS_LOG_FILE} ---"
    tail -n "${n}" "${AIOS_LOG_FILE}" 2>/dev/null || echo "(log empty)"
}

_aios_setup_status
log "INFO" "AIOS AI shell started. OS_ROOT=${OS_ROOT} AI_BACKEND=${AI_BACKEND:-mock}"

# ---------------------------------------------------------------------------
# SIGUSR1 handler — hot-reload plugins without restarting the shell
# ---------------------------------------------------------------------------
_aios_reload_plugins() {
    echo ""
    echo "[AIOS] SIGUSR1 received — reloading plugins ..."
    log "INFO" "Plugin hot-reload triggered (SIGUSR1)"
    if command -v python3 &>/dev/null; then
        python3 - <<PYEOF
import sys, os
sys.path.insert(0, '${AIOS_ROOT}/ai/core')
try:
    import plugin_loader, router as router_mod
    r = router_mod.Router(os_root='${OS_ROOT}', aios_root='${AIOS_ROOT}')
    loaded = plugin_loader.load_plugins(r, os_root='${OS_ROOT}')
    print(f"[AIOS] Loaded {len(loaded)} plugin(s): " + ", ".join(m.name for m in loaded) if loaded else "[AIOS] No plugins found.")
except Exception as e:
    print(f"[AIOS] Plugin reload error: {e}")
PYEOF
    else
        echo "[AIOS] python3 not found — cannot reload plugins"
    fi
    echo ""
}
trap '_aios_reload_plugins' USR1

# ---------------------------------------------------------------------------
# Main REPL
# ---------------------------------------------------------------------------
while true; do
    # Use readline-enabled read when in interactive terminal, plain read otherwise
    if [[ -t 0 ]]; then
        if ! read -r -e -p "${prompt}" line; then
            echo
            break
        fi
        # Add non-empty lines to history
        [[ -n "${line}" ]] && history -s "${line}"
    else
        if ! read -rp "${prompt}" line; then
            echo
            break
        fi
    fi

    # Strip leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "${line}" ]] && continue

    # ------------------------------------------------------------------
    # Built-in commands
    # ------------------------------------------------------------------
    case "${line}" in
        exit|quit)
            log "INFO" "AIOS AI shell exiting"
            # Save history
            history -a 2>/dev/null || true
            echo "Goodbye."
            break
            ;;

        help)
            cat <<'EOF'
AIOS AI Shell — built-in commands
══════════════════════════════════════════════════════
Filesystem (confined to OS_ROOT):
  fs.ls   [path]           List directory (default: /)
  fs.cat  <path>           Show file contents
  fs.write <path> <text>   Write text to file (creates parent dirs)
  fs.mkdir <path>          Create directory
  fs.rm   <path>           Remove path (recursive)
  fs.cp   <src> <dest>     Copy file or directory
  fs.mv   <src> <dest>     Move/rename
  fs.find [path] [args]    Find files

Process:
  proc.ps                  List top 50 processes
  proc.kill <pid>          Send SIGTERM to PID

Network:
  net.ping  [host]         Ping a host (default: 8.8.8.8)
  net.ifconfig             Show network interfaces

System:
  status                   Show live system status
  sysinfo                  Show host + environment info
  version                  Print AIOS version
  log.tail [n]             Show last N lines of aios.log (default: 20)
  clear                    Clear screen
  sys                      Enter real OS shell (unrestricted)
  sys -- <cmd> [args]      Run one AIOS command non-interactively

Other:
  help                     Show this help
  exit / quit              Exit AIOS

Natural language:
  Type anything else and the AI backend will interpret or respond.
  Typos in command names are automatically corrected (fuzzy matching).
  Up/Down arrow keys cycle through command history.
══════════════════════════════════════════════════════
EOF
            continue
            ;;

        version)
            echo "AIOS Aurora v1.0 — AI Operating System Shell"
            echo "  AIOS_ROOT : ${AIOS_ROOT}"
            echo "  OS_ROOT   : ${OS_ROOT}"
            echo "  AI backend: ${AI_BACKEND:-mock}"
            continue
            ;;

        status)
            _aios_status
            continue
            ;;

        sysinfo)
            _aios_sysinfo
            continue
            ;;

        clear)
            clear
            continue
            ;;

        log.tail|log.tail\ *)
            _rest="${line#log.tail}"
            _rest="${_rest# }"
            _aios_log_tail "${_rest:-20}"
            continue
            ;;

        # 'sys' alone → interactive real OS shell
        sys)
            log "INFO" "Entering real OS shell (${REAL_SHELL})"
            echo "[AIOS] Entering OS shell. Type 'exit' to return."
            "${AIOS_ROOT}/bin/aios-sys"
            echo "[AIOS] Returned from OS shell."
            continue
            ;;

        # 'sys -- <cmd> [args]' → run a single AIOS command via aios-sys
        sys\ --\ *)
            rest="${line#sys -- }"
            # shellcheck disable=SC2086
            set -- ${rest}
            "${AIOS_ROOT}/bin/aios-sys" -- "$@"
            continue
            ;;
    esac

    # ------------------------------------------------------------------
    # Try registered command dispatch
    # ------------------------------------------------------------------
    cmd_name="${line%% *}"
    if [[ "${line}" == *" "* ]]; then
        cmd_args="${line#"${cmd_name} "}"
    else
        cmd_args=""
    fi

    if run_command "${cmd_name}" ${cmd_args:+${cmd_args}}; then
        log "INFO" "Command executed: ${cmd_name}"
        continue
    fi

    # ------------------------------------------------------------------
    # Fuzzy typo correction
    # ------------------------------------------------------------------
    suggestion="$(aura_typo_suggest "${cmd_name}" 2>/dev/null || true)"
    if [[ -n "${suggestion}" ]]; then
        echo "[AIOS] Unknown command '${cmd_name}'. Did you mean '${suggestion}'? [Y/n]"
        if read -r -t 10 ans; then
            if [[ -z "${ans}" || "${ans}" =~ ^[Yy]$ ]]; then
                if run_command "${suggestion}" ${cmd_args:+${cmd_args}}; then
                    log "INFO" "Typo-corrected command executed: ${suggestion}"
                    continue
                fi
            fi
        fi
    fi

    # ------------------------------------------------------------------
    # Fall through to AI backend (natural language / chat)
    # ------------------------------------------------------------------
    # Sanitize input before passing to AI backend (Level 13 security)
    sanitized_line=$(sanitize_input "${line}")
    echo "[AIOS] Routing to AI..."
    log "INFO" "AI query: ${sanitized_line}"
    aura_ai_query "${sanitized_line}"

done

# Persist history on clean exit
history -a 2>/dev/null || true

