# build/buildroot/configs/aios_arm64_s21fe_defconfig
# Buildroot defconfig for AIOS-Lite on ARM64 / Samsung Galaxy S21 FE
#
# Target: aarch64 (Cortex-A78 big cores, 6–8 GB RAM variant)
# CPU affinity for LLM inference: cores 1–3 (big cluster)
# Thermal limit: 68 °C  (see config/llama-settings.conf)
#
# Usage (cross-compile on x86-64 host):
#   cd buildroot/
#   make BR2_EXTERNAL=<path-to>/build/buildroot aios_arm64_s21fe_defconfig
#   make

BR2_aarch64=y
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_PREINSTALLED=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_PREFIX="aarch64-linux-gnu"

# Device identity
BR2_TARGET_GENERIC_HOSTNAME="aioscpu-s21fe"
BR2_TARGET_GENERIC_ISSUE="AIOSCPU v1.0.0 (Aurora) — Samsung Galaxy S21 FE"

# Init system
BR2_INIT_SYSTEMD=y
BR2_PACKAGE_SYSTEMD=y

# Shell & scripting
BR2_PACKAGE_BASH=y
BR2_PACKAGE_BASH_COMPLETION=y

# Python AI core
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_PY_PYC=y
BR2_PACKAGE_PYTHON_CRYPTOGRAPHY=y

# Network
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_WIREGUARD_TOOLS=y
BR2_PACKAGE_AVAHI=y
BR2_PACKAGE_BLUEZ5_UTILS=y

# Utilities
BR2_PACKAGE_SUDO=y
BR2_PACKAGE_RSYNC=y
BR2_PACKAGE_CURL=y

# S21 FE device profile is selected at runtime via config/device-profiles/samsung-s21fe.conf
# LLAMA_CPU_AFFINITY is set to "1-3" in that profile (big Cortex-A78 cores)

# AIOS-Lite
BR2_PACKAGE_AIOS_LITE=y
